#!/usr/bin/env bash
# Shortcut cho các lệnh Docker development thường dùng.
#
# Cách dùng:
#   bin/docker rspec              → chạy toàn bộ test
#   bin/docker rspec spec/models  → chạy test 1 thư mục
#   bin/docker prspec             → chạy test song song (auto-detect số processes)
#   bin/docker prspec -n 5        → chạy test song song với 5 processes
#   bin/docker prspec:setup       → tạo databases cho test song song (chạy 1 lần)
#   bin/docker console            → mở Rails console
#   bin/docker bash               → mở shell trong container app
#   bin/docker bash postgres      → mở shell trong container postgres
#   bin/docker logs               → xem logs container app
#   bin/docker logs postgres      → xem logs container postgres
#   bin/docker ps                 → xem trạng thái containers
#   bin/docker up                 → khởi động Docker (foreground)
#   bin/docker stop               → dừng Docker
#   bin/docker start              → chạy lại Docker đã dừng
#   bin/docker down               → dừng + xóa containers
#   bin/docker exec app <lệnh>   → chạy lệnh trong container app
#   bin/docker exec postgres <lệnh> → chạy lệnh trong container postgres

set -e

COMPOSE="docker compose -f compose.dev.yml"

# Tự gán cổng host RIÊNG khi chạy trong git worktree.
#
# Compose đã tách container/network/volume theo project (lấy theo tên thư mục),
# nhưng cổng publish ra host là tài nguyên chung của cả máy: hai môi trường không
# thể cùng bind 5433/80. Nên mỗi git worktree cần một bộ cổng host riêng để chạy
# song song mà không đụng project gốc hay worktree khác.
#
# Thứ tự ưu tiên cho cổng web (nginx):
#   1. NGINX_HOST_PORT người dùng tự đặt → tôn trọng.
#   2. Biến PORT (preview_start với autoPort cấp cổng trống rồi truyền qua PORT)
#      → map nginx ra đúng cổng đó để preview kết nối được (cả worktree lẫn gốc).
#   3. Trong worktree → cổng ổn định suy ra từ đường dẫn worktree.
#   4. Còn lại (project gốc) → mặc định 80 trong compose.dev.yml.
# PostgreSQL: worktree dùng cổng ổn định riêng; gốc giữ mặc định 5433.
# Cổng worktree suy ra từ đường dẫn → cùng worktree luôn cùng cổng (tiện bookmark).
if [ -n "${PORT:-}" ]; then
  export NGINX_HOST_PORT="${NGINX_HOST_PORT:-$PORT}"
fi

if git rev-parse --git-dir 2>/dev/null | grep -q '/worktrees/'; then
  WORKTREE_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
  WORKTREE_PORT_HASH="$(printf '%s' "$WORKTREE_ROOT" | cksum | cut -d' ' -f1)"
  export POSTGRES_HOST_PORT="${POSTGRES_HOST_PORT:-$((20000 + WORKTREE_PORT_HASH % 10000))}"
  export NGINX_HOST_PORT="${NGINX_HOST_PORT:-$((30000 + WORKTREE_PORT_HASH % 10000))}"
fi

# Forward RAILS_ENV vào container nếu được set trên host.
# Không set → container dùng RAILS_ENV từ compose.dev.yml (development).
ENV_ARGS=()
[ -n "${RAILS_ENV:-}" ] && ENV_ARGS=(-e "RAILS_ENV=$RAILS_ENV")

case "${1}" in
  logs)
    shift
    $COMPOSE logs --tail 50 "${@:-app}"
    ;;
  ps)
    $COMPOSE ps
    ;;
  up)
    shift
    [ -n "${NGINX_HOST_PORT:-}" ] && echo "→ App (nginx): http://localhost:${NGINX_HOST_PORT}"
    [ -n "${POSTGRES_HOST_PORT:-}" ] && echo "→ PostgreSQL: localhost:${POSTGRES_HOST_PORT}"
    $COMPOSE up "$@"
    ;;
  stop)
    $COMPOSE stop
    ;;
  start)
    $COMPOSE start
    ;;
  down)
    shift
    $COMPOSE down "$@"
    ;;
  rspec)
    shift
    $COMPOSE exec -e RAILS_ENV=test app bundle exec rspec "$@"
    ;;
  prspec)
    shift
    if echo "$@" | grep -q -- "-n"; then
      $COMPOSE exec -e RAILS_ENV=test app bundle exec parallel_rspec spec/ "$@"
    else
      NCPU=$($COMPOSE exec -T app nproc)
      N=$(( NCPU / 2 ))
      [ "$N" -lt 2 ] && N=2
      $COMPOSE exec -e RAILS_ENV=test app bundle exec parallel_rspec spec/ -n "$N" "$@"
    fi
    ;;
  prspec:setup)
    $COMPOSE exec -e RAILS_ENV=test app bundle exec rails parallel:setup
    ;;
  console)
    $COMPOSE exec "${ENV_ARGS[@]}" app bundle exec rails console
    ;;
  bash)
    shift
    $COMPOSE exec "${ENV_ARGS[@]}" "${1:-app}" bash
    ;;
  exec)
    shift
    $COMPOSE exec "${ENV_ARGS[@]}" "$@"
    ;;
  *)
    $COMPOSE exec "${ENV_ARGS[@]}" app "$@"
    ;;
esac
