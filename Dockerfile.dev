# Dockerfile cho DEVELOPMENT.
# Khác production: không multi-stage build, không precompile assets.
# Source code mount từ máy Mac vào, không copy vào image.

ARG RUBY_VERSION=3.4.3
FROM docker.io/library/ruby:$RUBY_VERSION-slim

WORKDIR /rails

# Cài packages cần cho development (bao gồm cả build tools cho native gems)
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential git libpq-dev libyaml-dev pkg-config \
      curl gnupg lsb-release \
      libjemalloc2 libvips libyaml-0-2 locales && \
    install -d /usr/share/postgresql-common/pgdg && \
    curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc -o /usr/share/postgresql-common/pgdg/apt.postgresql.org.asc && \
    echo "deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.asc] https://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" > /etc/apt/sources.list.d/pgdg.list && \
    apt-get update -qq && \
    apt-get install --no-install-recommends -y postgresql-client-16 && \
    sed -i 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen && \
    locale-gen && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Chromium + chromedriver cho system test (Capybara + Selenium).
# Dùng gói Debian thay vì Google Chrome để image build/chạy được trên MỌI kiến trúc
# CPU mà nhóm dùng (cả Intel/amd64 lẫn ARM/arm64 như Apple Silicon): apt repo của
# Google Chrome chỉ có bản amd64 nên không cài được trên máy arm64, còn gói chromium
# của Debian có cả hai. Hai gói chromium và chromium-driver do Debian phát hành cùng
# một phiên bản nên chromedriver luôn khớp Chromium, không cần Selenium Manager tải
# driver lúc chạy (chạy được cả khi offline). fonts-liberation để Chromium render
# chữ đầy đủ.
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      chromium chromium-driver fonts-liberation && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Node.js LTS (v22) + npm-managed Playwright for demo recording (spec/demo, ADR-038).
# Use NodeSource repo so we get a current LTS instead of the outdated Debian package.
# package.json is copied here so npm install runs at build time (good layer caching);
# at runtime the bind-mount overlays /rails but node_modules is already present.
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install --no-install-recommends -y nodejs && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

COPY package.json ./
RUN npm install

# Install Playwright's Chromium browser + OS-level deps inside the image so the
# demo driver works from a freshly built image without any manual in-container steps.
RUN npx playwright install --with-deps chromium

# Foreman để chạy Procfile.dev (Rails server + Tailwind watcher)
RUN gem install foreman

ENV LANG="en_US.UTF-8" \
    LC_ALL="en_US.UTF-8" \
    TZ="Asia/Ho_Chi_Minh"

EXPOSE 3000
