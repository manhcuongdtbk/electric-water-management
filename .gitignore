# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env*.erb
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids/
!/tmp/pids/.keep
!/tmp/storage/
!/tmp/storage/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key
/config/credentials/*.key

# Ignore node_modules
/node_modules

# Ignore Yarn files
.yarn/
yarn-error.log

# macOS
.DS_Store

# RubyMine / IDEs
.idea/
.vscode/
*.swp
*.swo

# RSpec coverage
/coverage/

# Claude Code
/.claude/worktrees/
/.claude/projects/
