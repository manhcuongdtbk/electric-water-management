#!/bin/bash
# Chụp lại toàn bộ ảnh cho hướng dẫn sử dụng.
# Chạy: docs/scripts/capture-screenshots
#
# Yêu cầu: Docker dev đang chạy (bin/docker up), Node.js + puppeteer đã cài.
# Script tự reset database, tạo dữ liệu mẫu, chụp ảnh, lưu vào docs/images/.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$PROJECT_ROOT"

echo "=== 1/4: Kiểm tra Docker ==="
if ! docker compose -f compose.dev.yml ps --format json 2>/dev/null | grep -q '"app"'; then
  echo "Docker dev chưa chạy. Chạy 'bin/docker up' trước."
  exit 1
fi

echo "=== 2/4: Reset database + tạo dữ liệu mẫu ==="
docker compose -f compose.dev.yml exec app bin/rails db:reset 2>&1 | tail -3

# Đợi app sẵn sàng sau reset
for i in $(seq 1 30); do
  code=$(curl -s -o /dev/null -w "%{http_code}" http://localhost/up 2>/dev/null)
  if [ "$code" = "200" ]; then break; fi
  sleep 2
done

docker compose -f compose.dev.yml exec app bin/rails runner docs/scripts/seed.rb 2>&1 | tail -5

echo ""
echo "=== 3/4: Chụp ảnh ==="
node docs/scripts/capture.mjs 2>&1

echo ""
echo "=== 4/4: Kết quả ==="
count=$(ls docs/images/*.png 2>/dev/null | wc -l | tr -d ' ')
referenced=$(grep -c '^\!' docs/V2_HUONG_DAN_SU_DUNG.md 2>/dev/null || echo 0)
echo "  Ảnh trong thư mục: $count"
echo "  Ảnh reference trong HDSD: $referenced"
echo ""
echo "Kiểm tra ảnh: mở docs/V2_HUONG_DAN_SU_DUNG.md trong trình xem Markdown."
