require "rails_helper"

# Demo spec for <%= file_name.humanize %> — a narrated, recorded walkthrough for the
# owner (pre-merge) and the customer (pre-release). Runs in CI like any spec
# (green-to-merge → anti-drift). See ADR-036..041 (#343) + ADR-050/051 (#352).
#
# TODO(demo-author): replace the placeholder journey below with the real
