<%= form_with model: pump_station do |f| %>
  <% if pump_station.errors.any? %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
      <ul class="list-disc pl-4 space-y-0.5">
        <% pump_station.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-6 max-w-lg">
    <% if pump_station.new_record? %>
      <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-200 pb-2">
        <%= t("pump_stations.new.pump_station_section") %>
      </h2>
    <% end %>

    <div>
      <%= f.label :name, t("pump_stations.form.name"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
            required: true %>
    </div>

    <div>
      <%= f.label :zone_id, t("pump_stations.form.zone"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <% if @available_zones.any? %>
        <%= f.collection_select :zone_id, @available_zones, :id, :name,
              { prompt: t("pump_stations.form.zone_prompt") },
              { class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
                required: true } %>
      <% else %>
        <p class="text-sm text-gray-500 italic"><%= t("pump_stations.form.no_zones_available") %></p>
      <% end %>
    </div>

    <% if pump_station.new_record? %>
      <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-200 pb-2 pt-2">
        <%= t("pump_stations.new.first_meter_section") %>
      </h2>
      <p class="text-xs text-gray-500"><%= t("pump_stations.new.first_meter_hint") %></p>

      <div>
        <%= f.label :first_meter_name, t("pump_stations.form.first_meter_name"),
              class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :first_meter_name,
              class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
              required: true %>
      </div>

    <% end %>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit pump_station.new_record? ? t("pump_stations.form.submit_create") : t("pump_stations.form.submit_update"),
            class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors cursor-pointer" %>
      <%= link_to t("pump_stations.form.cancel"), pump_stations_path,
            class: "text-sm text-gray-600 hover:underline" %>
    </div>
  </div>
<% end %>
