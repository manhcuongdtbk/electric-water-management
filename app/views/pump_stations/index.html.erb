<% content_for :title, t("pump_stations.index.title") %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-xl font-semibold text-gray-900"><%= t("pump_stations.index.title") %></h1>
  <div class="flex items-center gap-2">
    <%= link_to t("pump_stations.index.readings_link"), pump_station_readings_path,
          class: "inline-flex items-center gap-1.5 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors" %>
    <%= link_to t("pump_stations.index.new_button"), new_pump_station_path,
          class: "inline-flex items-center gap-1.5 rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors" %>
  </div>
</div>

<div class="mb-4 rounded-md bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
  <%= t("pump_stations.index.note") %>
</div>

<% if @pump_stations.any? %>
  <% @pump_stations.each do |ps| %>
    <div class="bg-white rounded-lg border border-gray-200 mb-4 overflow-hidden"
         data-pump-station-id="<%= ps.id %>">
      <div class="px-4 py-3 border-b border-gray-200 bg-gray-50 flex items-center justify-between">
        <div>
          <h2 class="text-base font-medium text-gray-800"><%= ps.name %></h2>
          <p class="text-xs text-gray-500 mt-0.5"><%= ps.organization.name %></p>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to t("pump_stations.actions.edit"), edit_pump_station_path(ps),
                class: "text-xs text-blue-600 hover:text-blue-800 font-medium" %>
          <%= button_to t("pump_stations.actions.delete"), pump_station_path(ps),
                method: :delete,
                data: { turbo_confirm: t("pump_stations.actions.delete_confirm") },
                class: "text-xs text-red-600 hover:text-red-800 font-medium bg-transparent border-0 cursor-pointer p-0" %>
        </div>
      </div>

      <div class="px-4 py-3 border-b border-gray-200">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-xs font-semibold text-gray-600 uppercase tracking-wide">
            <%= t("pump_stations.index.meters_section") %>
          </h3>
          <%= link_to t("pump_stations.index.add_meter"), new_pump_station_meter_path(ps),
                class: "text-xs text-blue-600 hover:text-blue-800 font-medium" %>
        </div>
        <% if ps.meters.any? %>
          <table class="min-w-full text-sm">
            <thead>
              <tr class="text-left text-xs text-gray-500">
                <th class="py-1 pr-3 font-medium"><%= t("pump_station_meters.index.meter_name_col") %></th>
                <th class="py-1 pr-3 font-medium"><%= t("pump_station_meters.index.serial_col") %></th>
                <th class="py-1 pr-3 font-medium"><%= t("pump_station_meters.index.notes_col") %></th>
                <th class="py-1 font-medium text-right w-32"><%= t("pump_station_meters.index.actions_col") %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% ps.meters.sort_by { |m| [ m.position || 0, m.name.to_s ] }.each do |meter| %>
                <tr>
                  <td class="py-1.5 pr-3 text-gray-900"><%= meter.name %></td>
                  <td class="py-1.5 pr-3 text-gray-700"><%= meter.serial_number.presence || "—" %></td>
                  <td class="py-1.5 pr-3 text-gray-500 text-xs"><%= meter.notes.presence || "—" %></td>
                  <td class="py-1.5 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <%= link_to t("pump_station_meters.actions.edit"),
                            edit_pump_station_meter_path(ps, meter),
                            class: "text-xs text-blue-600 hover:text-blue-800 font-medium" %>
                      <%= button_to t("pump_station_meters.actions.delete"),
                            pump_station_meter_path(ps, meter),
                            method: :delete,
                            data: { turbo_confirm: t("pump_station_meters.actions.delete_confirm") },
                            class: "text-xs text-red-600 hover:text-red-800 font-medium bg-transparent border-0 cursor-pointer p-0" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class="text-xs text-gray-500 italic"><%= t("pump_stations.index.no_meters") %></p>
        <% end %>
      </div>

      <div class="px-4 py-3">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-xs font-semibold text-gray-600 uppercase tracking-wide">
            <%= t("pump_stations.index.assignments_section") %>
          </h3>
          <%= link_to t("pump_stations.index.add_assignment"),
                new_pump_station_assignment_path(ps),
                class: "text-xs text-blue-600 hover:text-blue-800 font-medium" %>
        </div>
        <% if ps.pump_station_assignments.any? %>
          <table class="min-w-full text-sm">
            <thead>
              <tr class="text-left text-xs text-gray-500">
                <th class="py-1 pr-3 font-medium"><%= t("pump_station_assignments.index.organization_col") %></th>
                <th class="py-1 pr-3 font-medium text-right"><%= t("pump_station_assignments.index.fixed_pct_col") %></th>
                <th class="py-1 font-medium text-right w-32"><%= t("pump_station_assignments.index.actions_col") %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% ps.pump_station_assignments.sort_by { |a| a.organization.position }.each do |asg| %>
                <tr>
                  <td class="py-1.5 pr-3 text-gray-900"><%= asg.organization.name %></td>
                  <td class="py-1.5 pr-3 text-right">
                    <% if asg.fixed? %>
                      <span class="font-medium text-amber-700"><%= number_with_delimiter(asg.fixed_pump_percentage) %>%</span>
                    <% else %>
                      <span class="text-gray-400 italic"><%= t("pump_station_assignments.index.variable") %></span>
                    <% end %>
                  </td>
                  <td class="py-1.5 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <%= link_to t("pump_station_assignments.actions.edit"),
                            edit_pump_station_assignment_path(ps, asg),
                            class: "text-xs text-blue-600 hover:text-blue-800 font-medium" %>
                      <%= button_to t("pump_station_assignments.actions.delete"),
                            pump_station_assignment_path(ps, asg),
                            method: :delete,
                            data: { turbo_confirm: t("pump_station_assignments.actions.delete_confirm") },
                            class: "text-xs text-red-600 hover:text-red-800 font-medium bg-transparent border-0 cursor-pointer p-0" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class="text-xs text-gray-500 italic"><%= t("pump_station_assignments.index.no_assignments") %></p>
        <% end %>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="bg-white rounded-lg border border-gray-200 px-4 py-6 text-sm text-gray-500 italic text-center">
    <%= t("pump_stations.index.empty") %>
  </div>
<% end %>
