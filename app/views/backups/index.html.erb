<% content_for :title, t("backups.index.title") %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-gray-900"><%= t("backups.index.title") %></h2>
  <%= button_to backups_path,
        method: :post,
        class: "inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
    </svg>
    <%= t("backups.index.backup_button") %>
  <% end %>
</div>

<div class="mb-4 rounded-md bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
  <div class="flex items-start gap-2">
    <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
    </svg>
    <%= t("backups.index.restore_warning") %>
  </div>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <% if @backups.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-12">
            <%= t("backups.index.columns.stt") %>
          </th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t("backups.index.columns.filename") %>
          </th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-32">
            <%= t("backups.index.columns.size") %>
          </th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-48">
            <%= t("backups.index.columns.created_at") %>
          </th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-40">
            <%= t("backups.index.columns.actions") %>
          </th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% @backups.each_with_index do |backup, idx| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-sm text-gray-500"><%= idx + 1 %></td>
            <td class="px-4 py-3 text-sm font-mono text-gray-900"><%= backup[:name] %></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= number_to_human_size(backup[:size]) %></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= l(backup[:created_at], format: :default) %></td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-2">
                <%= button_to restore_backups_path,
                      method: :post,
                      params: { filename: backup[:name] },
                      data: { turbo_confirm: t("backups.index.restore_confirm") },
                      class: "inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-white bg-green-600 rounded hover:bg-green-700 transition-colors" do %>
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                  <%= t("backups.index.actions.restore") %>
                <% end %>
                <%= button_to destroy_file_backups_path,
                      method: :delete,
                      params: { filename: backup[:name] },
                      data: { turbo_confirm: t("backups.index.delete_confirm") },
                      class: "inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-white bg-red-600 rounded hover:bg-red-700 transition-colors" do %>
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                  <%= t("backups.index.actions.delete") %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-4 py-12 text-center text-sm text-gray-500">
      <svg class="mx-auto mb-3 w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z" />
      </svg>
      <%= t("backups.index.empty") %>
    </div>
  <% end %>
</div>
