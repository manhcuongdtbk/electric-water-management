<%= form_with model: contact_point_group do |f| %>
  <% if contact_point_group.errors.any? %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
      <ul class="list-disc pl-4 space-y-0.5">
        <% contact_point_group.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4 max-w-2xl">
    <div>
      <%= f.label :name, t("contact_point_groups.form.name"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
            required: true %>
    </div>

    <div>
      <p class="block text-sm font-medium text-gray-700 mb-1"><%= t("contact_point_groups.form.members") %></p>
      <p class="text-xs text-gray-500 mb-2"><%= t("contact_point_groups.form.members_hint") %></p>
      <div class="space-y-1 max-h-60 overflow-y-auto border border-gray-200 rounded-md px-3 py-2">
        <% if @available_contact_points.any? %>
          <% @available_contact_points.each do |cp| %>
            <label class="flex items-center gap-2 text-sm text-gray-700 py-1 cursor-pointer hover:text-gray-900">
              <%= check_box_tag "contact_point_group[contact_point_ids][]",
                    cp.id,
                    contact_point_group.contact_point_ids.include?(cp.id),
                    id: "contact_point_group_contact_point_ids_#{cp.id}" %>
              <%= cp.name %>
              <% if cp.group_name.present? %>
                <span class="text-xs text-gray-400">(<%= cp.group_name %>)</span>
              <% end %>
            </label>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-500 italic py-2">—</p>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit contact_point_group.new_record? ? t("contact_point_groups.form.submit_create") : t("contact_point_groups.form.submit_update"),
            class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors cursor-pointer" %>
      <%= link_to t("contact_point_groups.form.cancel"), contact_point_groups_path,
            class: "text-sm text-gray-600 hover:underline" %>
    </div>
  </div>
<% end %>
