<% if @summary.unit.nil? %>
  <div class="bg-gray-50 border border-gray-200 rounded p-4 text-gray-600">
    Tài khoản chưa được gán đơn vị.
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
      <h3 class="text-xs font-semibold text-gray-500 uppercase mb-1">Tổng thâm điện</h3>
      <p class="text-2xl font-semibold text-red-700"><%= number_to_vi(@summary.deficit_kw) %> kW</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
      <h3 class="text-xs font-semibold text-gray-500 uppercase mb-1">Thành tiền phải thu</h3>
      <p class="text-2xl font-semibold text-gray-900"><%= money_to_vi(@summary.deficit_amount) %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
      <h3 class="text-xs font-semibold text-gray-500 uppercase mb-1">Số đầu mối thiếu</h3>
      <p class="text-2xl font-semibold text-red-700"><%= @summary.deficit_count %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
      <h3 class="text-xs font-semibold text-gray-500 uppercase mb-1">Số đầu mối thừa</h3>
      <p class="text-2xl font-semibold text-green-700"><%= @summary.surplus_count %></p>
    </div>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
    <h3 class="text-xs font-semibold text-gray-500 uppercase mb-2">Trạng thái nhập liệu kỳ hiện tại</h3>
    <% if @summary.input_status == :entered %>
      <span class="inline-block px-3 py-1 rounded bg-green-100 text-green-700 font-medium">Đã nhập</span>
    <% else %>
      <span class="inline-block px-3 py-1 rounded bg-yellow-100 text-yellow-800 font-medium">Chưa nhập</span>
    <% end %>
  </div>
<% end %>
