<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
  <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
    <h3 class="text-xs font-semibold text-gray-500 uppercase mb-1">Sử dụng điện công cộng toàn khu vực</h3>
    <p class="text-2xl font-semibold text-gray-900"><%= number_to_vi(@summary.public_total_usage) %> kW</p>
  </div>
  <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
    <h3 class="text-xs font-semibold text-gray-500 uppercase mb-1">Sử dụng điện bơm nước toàn khu vực</h3>
    <p class="text-2xl font-semibold text-gray-900"><%= number_to_vi(@summary.pump_total_usage) %> kW</p>
  </div>
</div>

<div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700">Đơn vị</th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700">Khu vực</th>
        <th class="px-4 py-2 text-right text-xs font-semibold text-gray-700">Tổng thâm điện (kW)</th>
        <th class="px-4 py-2 text-right text-xs font-semibold text-gray-700">Thành tiền phải thu</th>
        <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700">Trạng thái nhập liệu</th>
      </tr>
    </thead>
    <tbody>
      <% @summary.units.each do |data| %>
        <tr class="border-t border-gray-100 hover:bg-yellow-50">
          <td class="px-4 py-2"><%= data[:unit].name %></td>
          <td class="px-4 py-2 text-gray-600"><%= data[:unit].zone&.name %></td>
          <td class="px-4 py-2 text-right text-red-700 font-medium"><%= number_to_vi(data[:deficit_kw]) %></td>
          <td class="px-4 py-2 text-right"><%= money_to_vi(data[:deficit_amount]) %></td>
          <td class="px-4 py-2 text-center">
            <% if data[:input_status] == :entered %>
              <span class="inline-block px-2 py-0.5 rounded bg-green-100 text-green-700 text-xs">Đã nhập</span>
            <% else %>
              <span class="inline-block px-2 py-0.5 rounded bg-yellow-100 text-yellow-800 text-xs">Chưa nhập</span>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @summary.units.empty? %>
        <tr>
          <td colspan="5" class="px-4 py-6 text-center text-gray-500">Chưa có đơn vị nào.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
