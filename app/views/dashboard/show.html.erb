<% page_title "Tổng quan" %>

<% if @no_period %>
  <%= render "no_period" %>
<% else %>
  <div class="mb-4">
    <h1 class="text-xl font-semibold"><%= period_label(@period) %></h1>
    <p class="text-sm text-gray-600 mt-1">
      Đơn giá: <strong><%= money_to_vi(@period.unit_price) %>/kW</strong>
      <% if @period.open? %>
        <span class="ml-2 px-2 py-0.5 rounded bg-green-100 text-green-700 text-xs">Đang mở</span>
      <% else %>
        <span class="ml-2 px-2 py-0.5 rounded bg-gray-200 text-gray-700 text-xs">Đã đóng</span>
      <% end %>
    </p>
  </div>

  <%= render "warnings", warnings: @summary.warnings %>

  <% if @summary.role == :system_admin %>
    <%= render "system_admin" %>
  <% else %>
    <%= render "unit_view" %>
  <% end %>
<% end %>
