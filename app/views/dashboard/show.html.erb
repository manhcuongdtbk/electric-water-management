<% page_title "Tổng quan" %>

<% if @no_period %>
  <%= render "no_period" %>
<% else %>
  <% if @period.open? && (current_user.unit_admin? || current_user.system_admin?) %>
    <%= render "shared/open_period_banner", period: @period %>
  <% end %>

  <%= render "warnings", warnings: @summary.warnings %>

  <p class="text-sm text-gray-700 mb-4">
    Đơn giá điện: <strong><%= money_to_vi(@period.unit_price) %>/kW</strong>
  </p>

  <% if @summary.role == :system_admin %>
    <%= render "system_admin" %>
  <% else %>
    <%= render "unit_view" %>
  <% end %>
<% end %>
