<% available_units = Unit.kept.accessible_by(current_ability) %>
<% mode_default = contact_point.zone_id.present? ? "zone" : "unit" %>

<fieldset class="border border-gray-200 rounded p-3"
          data-controller="contact-point-assignment">
  <legend class="text-sm font-medium text-gray-700 px-1">Đầu mối thuộc về</legend>

  <% unless current_user.unit_id.present? && !current_zone_manager? %>
    <div class="flex gap-4 mb-3">
      <label class="flex items-center gap-2 text-sm">
        <input type="radio" name="assignment_mode" value="unit"
               <%= "checked" if mode_default == "unit" %>
               <%= "disabled" if contact_point.persisted? %>
               data-contact-point-assignment-target="mode"
               data-action="change->contact-point-assignment#refresh">
        <span>Đơn vị</span>
      </label>
      <label class="flex items-center gap-2 text-sm">
        <input type="radio" name="assignment_mode" value="zone"
               <%= "checked" if mode_default == "zone" %>
               <%= "disabled" if contact_point.persisted? %>
               data-contact-point-assignment-target="mode"
               data-action="change->contact-point-assignment#refresh">
        <span>Khu vực (cấp khu vực, không thuộc đơn vị nào)</span>
      </label>
    </div>
  <% end %>

  <div data-contact-point-assignment-target="unitGroup">
    <%= f.label :unit_id, "Đơn vị", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% if current_user.unit_id.present? %>
      <%= f.hidden_field :unit_id %>
      <input type="text" disabled value="<%= current_user.unit.name %>"
             class="block w-full rounded border border-gray-300 px-3 py-2 text-sm bg-gray-50">
    <% else %>
      <%= f.select :unit_id, available_units.order(:name).pluck(:name, :id),
          { include_blank: "— Chọn đơn vị —" },
          class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm",
          disabled: contact_point.persisted? %>
    <% end %>
  </div>

  <div data-contact-point-assignment-target="zoneGroup">
    <%= f.label :zone_id, "Khu vực", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% if current_user.unit_id.present? %>
      <%= f.hidden_field :zone_id, value: current_user.unit.zone_id %>
      <input type="text" disabled value="<%= current_user.unit.zone&.name %>"
             class="block w-full rounded border border-gray-300 px-3 py-2 text-sm bg-gray-50">
    <% else %>
      <%= f.select :zone_id, available_zones.order(:name).pluck(:name, :id),
          { include_blank: "— Chọn khu vực —" },
          class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm",
          disabled: contact_point.persisted? %>
    <% end %>
    <p class="text-xs text-gray-500 mt-1">
      Đầu mối công cộng cấp khu vực. Không thuộc đơn vị nào.
    </p>
  </div>

  <% if contact_point.persisted? %>
    <p class="text-xs text-gray-500 mt-2">Không thể đổi nơi thuộc về sau khi tạo.</p>
  <% end %>
</fieldset>

<%= render "meters_fields", f: f, contact_point: contact_point %>
