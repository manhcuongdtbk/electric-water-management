
<div>
  <%= f.label :zone_id, "Khu vực", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.select :zone_id, available_zones.order(:name).pluck(:name, :id),
      { include_blank: "— Chọn khu vực —" },
      class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm",
      disabled: contact_point.persisted? %>
</div>

<div>
  <%= f.label :personnel_count, "Quân số (tổng)", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.number_field :personnel_count, step: 1,
      class: "w-32 rounded border border-gray-300 px-3 py-2 text-sm" %>
  <p class="text-xs text-gray-500 mt-1">Đầu mối ngoài biên chế không phân theo nhóm cấp bậc.</p>
</div>
