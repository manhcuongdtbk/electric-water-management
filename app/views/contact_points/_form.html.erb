<%= form_with model: contact_point, class: "space-y-4" do |f| %>
  <% if contact_point.errors.any? %>
    <div class="rounded-md bg-red-50 border border-red-200 px-4 py-3">
      <p class="text-sm font-medium text-red-800 mb-1">Có <%= contact_point.errors.count %> lỗi cần sửa:</p>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-0.5">
        <% contact_point.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if current_user.admin_level1? %>
    <div>
      <%= f.label :organization_id, t("contact_points.form.organization"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :organization_id,
            options_from_collection_for_select(@organizations, :id, :name, contact_point.organization_id),
            { include_blank: t("contact_points.form.organization_prompt") },
            class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, t("contact_points.form.name"),
          class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
          placeholder: "Ví dụ: Ban Tác huấn, Tổ xe..." %>
  </div>

  <div>
    <%= f.label :group_name, t("contact_points.form.group_name"),
          class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :group_name,
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
          placeholder: "Ví dụ: Ban Tham mưu, Ban Hậu cần..." %>
    <p class="mt-1 text-xs text-gray-500">Để trống nếu không thuộc nhóm nào.</p>
  </div>

  <div>
    <%= f.label :contact_point_type, t("activerecord.attributes.contact_point.contact_point_type"),
          class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :contact_point_type,
          ContactPoint.contact_point_types.keys.map { |key|
            [ t("activerecord.attributes.contact_point.contact_point_types.#{key}"), key ]
          },
          {},
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    <p class="mt-1 text-xs text-gray-500"><%= t("contact_points.form.contact_point_type_hint") %></p>
  </div>

  <div>
    <%= f.label :position, t("contact_points.form.position"),
          class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :position, min: 0,
          class: "block w-32 border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    <p class="mt-1 text-xs text-gray-500">Số nhỏ hơn hiển thị trước.</p>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit(contact_point.new_record? ? t("contact_points.form.submit_create") : t("contact_points.form.submit_update"),
          class: "px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 cursor-pointer transition-colors") %>
    <%= link_to t("contact_points.actions.cancel"), contact_points_path,
          class: "px-5 py-2 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
