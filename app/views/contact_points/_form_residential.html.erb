<% available_units = Unit.kept.accessible_by(current_ability) %>
<% available_blocks = Block.kept.accessible_by(current_ability).order(:name) %>
<% available_groups = Group.kept.accessible_by(current_ability).order(:name) %>
<% mode_default = contact_point.zone_id.present? ? "zone" : "unit" %>

<fieldset class="border border-gray-200 rounded p-3"
          data-controller="contact-point-assignment">
  <legend class="text-sm font-medium text-gray-700 px-1">Đầu mối thuộc về</legend>

  <% unless current_user.unit_id.present? && !current_zone_manager? && contact_point.new_record? %>
    <div class="flex gap-4 mb-3">
      <label class="flex items-center gap-2 text-sm">
        <input type="radio" name="assignment_mode" value="unit"
               <%= "checked" if mode_default == "unit" %>
               <%= "disabled" if contact_point.persisted? %>
               data-contact-point-assignment-target="mode"
               data-action="change->contact-point-assignment#refresh">
        <span>Đơn vị</span>
      </label>
      <label class="flex items-center gap-2 text-sm">
        <input type="radio" name="assignment_mode" value="zone"
               <%= "checked" if mode_default == "zone" %>
               <%= "disabled" if contact_point.persisted? %>
               data-contact-point-assignment-target="mode"
               data-action="change->contact-point-assignment#refresh">
        <span>Khu vực (cấp khu vực, không thuộc đơn vị nào)</span>
      </label>
    </div>
  <% end %>

  <div data-contact-point-assignment-target="unitGroup" class="space-y-3">
    <div>
      <%= f.label :unit_id, "Đơn vị", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <% if current_user.unit_id.present? %>
        <%= f.hidden_field :unit_id, data: { contact_point_assignment_target: "unitSelect" } %>
        <input type="text" disabled value="<%= current_user.unit.name %>"
               class="block w-full rounded border border-gray-300 px-3 py-2 text-sm bg-gray-50">
      <% else %>
        <%= f.select :unit_id, available_units.order(:name).pluck(:name, :id),
            { include_blank: "— Chọn đơn vị —" },
            class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm",
            disabled: contact_point.persisted?,
            data: { contact_point_assignment_target: "unitSelect",
                    action: "change->contact-point-assignment#refreshUnitScope" } %>
      <% end %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :block_id, "Khối (tùy chọn)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :block_id,
            available_blocks.map { |b| [b.name, b.id, { "data-unit-id": b.unit_id }] },
            { include_blank: "— Không thuộc khối —" },
            class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm",
            data: { contact_point_assignment_target: "blockSelect",
                    action: "change->contact-point-assignment#refreshBlockScope" } %>
      </div>
      <div>
        <%= f.label :group_id, "Nhóm (tùy chọn)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :group_id,
            available_groups.map { |g| [g.name, g.id, { "data-unit-id": g.unit_id, "data-block-id": g.block_id || "" }] },
            { include_blank: "— Không thuộc nhóm —" },
            class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm",
            data: { contact_point_assignment_target: "groupSelect" } %>
      </div>
    </div>
  </div>

  <div data-contact-point-assignment-target="zoneGroup">
    <%= f.label :zone_id, "Khu vực", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :zone_id, available_zones.order(:name).pluck(:name, :id),
        { include_blank: "— Chọn khu vực —" },
        class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm",
        disabled: contact_point.persisted? %>
    <p class="text-xs text-gray-500 mt-1">
      Đầu mối sinh hoạt cấp khu vực (vd: "Chỉ huy khu vực"). Không thuộc đơn vị, không có khối/nhóm.
    </p>
  </div>

  <% if contact_point.persisted? %>
    <p class="text-xs text-gray-500 mt-2">Không thể đổi nơi thuộc về sau khi tạo.</p>
  <% end %>
</fieldset>

<% if current_period %>
  <% ranks = current_period.ranks.order(:position) %>
  <% existing_entries = contact_point.persisted? ?
       contact_point.personnel_entries.where(period: current_period).index_by(&:rank_id) :
       {} %>
  <div>
    <h3 class="text-sm font-semibold text-gray-700 mb-2">Quân số theo nhóm cấp bậc (kỳ tháng <%= current_period.month %>/<%= current_period.year %>)</h3>
    <div class="space-y-2">
      <% ranks.each do |rank| %>
        <% entry = existing_entries[rank.id] %>
        <div class="flex items-center space-x-2">
          <label class="flex-1 text-sm text-gray-700"><%= rank.name %></label>
          <% if entry %>
            <%= hidden_field_tag "contact_point[personnel_lock_versions][#{rank.id}]", entry.lock_version %>
          <% end %>
          <%= number_field_tag "contact_point[personnel_counts][#{rank.id}]",
              entry&.count || 0, step: 1,
              class: "w-24 rounded border border-gray-300 px-2 py-1 text-sm text-right" %>
        </div>
      <% end %>
    </div>
    <p class="text-xs text-gray-500 mt-2">Tổng quân số phải ≥ 1.</p>
  </div>
<% else %>
  <div class="bg-yellow-50 border border-yellow-200 rounded p-3 text-sm text-yellow-800">
    Không có kỳ đang mở. Không thể nhập quân số. Đầu mối sẽ được tạo nhưng cần kỳ mở để có hiệu lực tính toán.
  </div>
<% end %>

<%= render "meters_fields", f: f, contact_point: contact_point %>
