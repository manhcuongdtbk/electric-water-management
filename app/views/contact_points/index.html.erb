<% page_title "Đầu mối" %>

<div class="flex justify-between items-center mb-4">
  <div class="flex space-x-2">
    <%= link_to "Tất cả", contact_points_path,
        class: "px-3 py-1 rounded text-sm #{params[:type].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700'}" %>
    <%= link_to "Sinh hoạt", contact_points_path(type: "residential"),
        class: "px-3 py-1 rounded text-sm #{params[:type] == 'residential' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700'}" %>
    <%= link_to "Công cộng", contact_points_path(type: "public"),
        class: "px-3 py-1 rounded text-sm #{params[:type] == 'public' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700'}" %>
    <%= link_to "Bơm nước", contact_points_path(type: "water_pump"),
        class: "px-3 py-1 rounded text-sm #{params[:type] == 'water_pump' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700'}" %>
    <%= link_to "Ngoài biên chế", contact_points_path(type: "non_establishment"),
        class: "px-3 py-1 rounded text-sm #{params[:type] == 'non_establishment' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700'}" %>
  </div>
  <%= link_to "Thêm đầu mối", new_contact_point_path(type: @filter_type),
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700" %>
</div>

<%= form_with url: contact_points_path, method: :get, local: true, class: "mb-4 flex space-x-2" do |f| %>
  <% if @filter_type %>
    <%= hidden_field_tag :type, @filter_type %>
  <% end %>
  <%= text_field_tag :q, params[:q], placeholder: "Tìm theo tên...",
      class: "flex-1 rounded border border-gray-300 px-3 py-2 text-sm" %>
  <%= submit_tag "Tìm", class: "bg-gray-100 text-gray-700 px-4 py-2 rounded text-sm font-medium hover:bg-gray-200 cursor-pointer" %>
<% end %>

<div class="text-sm text-gray-600 mb-2">
  Tổng số: <strong><%= @total_count %></strong>
</div>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Tên</th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Loại</th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Đơn vị / Khu vực</th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Khối / Nhóm</th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Công tơ</th>
        <th class="px-4 py-2 text-right text-xs font-semibold text-gray-600 uppercase">Thao tác</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @contact_points.each do |cp| %>
        <tr>
          <td class="px-4 py-2 text-sm font-medium text-gray-900"><%= cp.name %></td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <%= t("activerecord.attributes.contact_point.types.#{cp.contact_point_type}", default: cp.contact_point_type) %>
          </td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <%= cp.unit&.name || cp.zone&.name %>
          </td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <%= [cp.block&.name, cp.group&.name].compact.join(" / ") %>
          </td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <%= cp.meters.kept.pluck(:name).join(", ") %>
          </td>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if can?(:update, cp) %>
              <%= link_to "Sửa", edit_contact_point_path(cp), class: "text-blue-600 hover:text-blue-800" %>
            <% end %>
            <% if can?(:destroy, cp) %>
              <%= button_to "Xóa", contact_point_path(cp), method: :delete,
                  form: { data: { turbo_confirm: "Xác nhận xóa đầu mối \"#{cp.name}\"?" } },
                  class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
