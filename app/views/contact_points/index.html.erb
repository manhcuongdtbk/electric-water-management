<% page_title t("sidebar.items.contact_points") %>


<%
  add_link = can?(:create, ContactPoint) ?
    link_to(t("common.actions.add") + " " + t("resources.contact_point"),
      new_contact_point_path(type: @filter_type),
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700") : nil

  type_options = @visible_types.map { |t| [I18n.t("activerecord.attributes.contact_point.types.#{t}"), t] }

  show_zone_unit = current_user.system_wide_scope?

  toolbar_filters = [
    { label: "Loại:", param: :type, options: type_options, selected: @filter_type }
  ]
  if show_zone_unit
    toolbar_filters += [
      { label: "Khu vực:", param: :zone_id,
        options: @available_zones.pluck(:name, :id), selected: @zone&.id,
        children: [:unit_id] },
      { label: "Đơn vị:", param: :unit_id,
        options: @available_units.pluck(:name, :id), selected: @unit&.id }
    ]
  end
  extra_sort_params = { q: params[:q], per_page: params[:per_page],
                        type: params[:type], zone_id: params[:zone_id], unit_id: params[:unit_id] }
%>

<%= render "shared/list_toolbar",
      url: contact_points_path,
      search_placeholder: "Tìm theo tên đầu mối...",
      total_count: @total_count,
      add_link: add_link,
      per_page_storage_key: "contact_points_per_page",
      filters: toolbar_filters %>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <%= sortable_header :name, "Đầu mối",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: extra_sort_params %>
        <%= sortable_header :contact_point_type, "Loại",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: extra_sort_params %>
        <%= sortable_header :group, "Nhóm",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: extra_sort_params %>
        <%= sortable_header :block, "Khối",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: extra_sort_params %>
        <% if show_zone_unit %>
          <%= sortable_header :unit, "Đơn vị",
                current_sort: params[:sort], current_dir: params[:dir],
                extra_params: extra_sort_params %>
          <%= sortable_header :zone, "Khu vực",
                current_sort: params[:sort], current_dir: params[:dir],
                extra_params: extra_sort_params %>
        <% end %>
        <%= list_header t("common.list.actions"), align: :right %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @contact_points.empty? %>
        <tr><td colspan="<%= show_zone_unit ? 7 : 5 %>" class="px-4 py-6 text-center text-gray-500"><%= t("common.list.no_records") %></td></tr>
      <% end %>
      <% @contact_points.each do |cp| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-2 text-sm font-medium text-gray-900"><%= cp.name %></td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <%= t("activerecord.attributes.contact_point.types.#{cp.contact_point_type}", default: cp.contact_point_type) %>
          </td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= cp.group&.name || "—" %></td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= cp.block&.name || "—" %></td>
          <% if show_zone_unit %>
            <td class="px-4 py-2 text-sm text-gray-600"><%= cp.unit&.name || "—" %></td>
            <td class="px-4 py-2 text-sm text-gray-600"><%= cp.zone&.name || cp.unit&.zone&.name || "—" %></td>
          <% end %>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if can?(:update, cp) || can?(:destroy, cp) %>
              <% if can?(:update, cp) %>
                <%= link_to t("common.actions.edit"), edit_contact_point_path(cp),
                      class: "text-blue-600 hover:text-blue-800" %>
              <% end %>
              <% if can?(:destroy, cp) %>
                <%= button_to t("common.actions.destroy"), contact_point_path(cp), method: :delete,
                      form: { class: "inline", data: { turbo_confirm: t("common.confirm.destroy_named", name: cp.name) } },
                      class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
              <% end %>
            <% else %>
              <%= empty_actions_dash %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
