<%= form_with model: [ contact_point, meter ], class: "space-y-4" do |f| %>
  <% if meter.errors.any? %>
    <div class="rounded-md bg-red-50 border border-red-200 px-4 py-3">
      <p class="text-sm font-medium text-red-800 mb-1">Có <%= meter.errors.count %> lỗi cần sửa:</p>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-0.5">
        <% meter.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, t("meters.form.name"),
          class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
          placeholder: "Ví dụ: Công tơ tầng 1, Công tơ nhà xe..." %>
  </div>

  <div>
    <%= f.label :meter_type, t("meters.form.meter_type"),
          class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :meter_type,
          Meter::CONTACT_POINT_FORM_TYPES.map { |type| [ t("meters.meter_types.#{type}"), type ] },
          {},
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    <p class="mt-1 text-xs text-gray-500"><%= t("meters.form.meter_type_hint") %></p>
  </div>

  <div class="flex items-start gap-2">
    <%= f.check_box :no_loss, class: "mt-1" %>
    <div>
      <%= f.label :no_loss, t("activerecord.attributes.meter.no_loss"),
            class: "block text-sm font-medium text-gray-700" %>
      <p class="text-xs text-gray-500"><%= t("meters.form.no_loss_hint") %></p>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit(meter.new_record? ? t("meters.form.submit_create") : t("meters.form.submit_update"),
          class: "px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 cursor-pointer transition-colors") %>
    <%= link_to t("meters.actions.cancel"), contact_point_meters_path(contact_point),
          class: "px-5 py-2 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
