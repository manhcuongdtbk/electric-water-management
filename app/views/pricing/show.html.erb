<% page_title "Đơn giá điện" %>

<div class="space-y-6">
  <!-- 1. Đơn giá kỳ hiện tại -->
  <% if @current_period %>
    <div class="bg-white rounded-lg shadow border border-gray-200 p-6">
      <h2 class="text-lg font-semibold mb-4">Kỳ đang mở: <%= period_label(@current_period) %></h2>
      <% if can?(:update, @current_period) %>
        <%= form_with model: @current_period, url: pricing_path, method: :patch, local: true,
            html: { class: "space-y-4" } do |f| %>
          <% if @current_period.errors.any? %>
            <div class="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
              <ul class="list-disc list-inside">
                <% @current_period.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :unit_price, "Đơn giá (VND/kWh)", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.number_field :unit_price, step: "0.01",
                  class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :water_pump_standard, "Tiêu chuẩn bơm nước (kWh/người)", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.number_field :water_pump_standard, step: "0.01",
                  class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :savings_rate, "Tỷ lệ tiết kiệm của Bộ (%)", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.number_field :savings_rate, step: "0.01",
                  class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= f.label :division_public_rate, "Công cộng Sư đoàn (%)", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.number_field :division_public_rate, step: "0.01",
                  class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
            </div>
          </div>

          <div class="pt-2">
            <%= f.submit "Lưu cập nhật", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 cursor-pointer" %>
          </div>
        <% end %>

        <div class="mt-4 pt-4 border-t border-gray-200">
          <div class="bg-amber-50 border border-amber-200 rounded p-3 mb-3 text-sm text-amber-800">
            <strong>Lưu ý khi đóng kỳ:</strong>
            <ul class="list-disc list-inside mt-1 space-y-1">
              <li>Hãy đảm bảo đã hoàn tất cả nhập liệu lẫn cấu trúc trước khi đóng kỳ.</li>
              <li>Sau khi đóng, toàn bộ số liệu của kỳ này sẽ bị khóa — không ai có thể chỉnh sửa.</li>
              <li>Nếu sau này cần mở lại kỳ đã đóng (phải đóng hết các kỳ đang mở trước):
                <ul class="list-disc list-inside ml-4 mt-1 space-y-1">
                  <li>Được phép sửa nhập liệu: số điện lực, chỉ số công tơ, tổn hao công tơ, chỉ số bơm nước, quân số đầu mối theo nhóm cấp bậc, quân số đầu mối ngoài biên chế, khấu trừ khác, tỷ lệ công cộng đơn vị, phân bổ bơm nước.</li>
                  <li>Không thể thay đổi cấu trúc: khu vực, đơn vị, đầu mối, công tơ, công tơ tổng, khối, nhóm, nhóm cấp bậc.</li>
                </ul>
              </li>
            </ul>
          </div>
          <div class="flex justify-end">
            <%= button_to "Đóng kỳ hiện tại", close_period_pricing_path,
                method: :post,
                params: { period_id: @current_period.id },
                form: { data: { turbo_confirm: "Đóng kỳ tháng #{@current_period.month}/#{@current_period.year}?\n\nToàn bộ số liệu sẽ bị khóa. Vui lòng đọc kỹ lưu ý trước khi xác nhận." } },
                class: "bg-red-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-red-700 cursor-pointer" %>
          </div>
        </div>
      <% else %>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div><span class="font-medium text-gray-700">Đơn giá:</span> <%= unit_price_to_vi(@current_period.unit_price) %> đ/kW</div>
          <div><span class="font-medium text-gray-700">Tiêu chuẩn bơm nước:</span> <%= @current_period.water_pump_standard %> kWh/người</div>
          <div><span class="font-medium text-gray-700">Tỷ lệ tiết kiệm của Bộ:</span> <%= @current_period.savings_rate %>%</div>
          <div><span class="font-medium text-gray-700">Công cộng Sư đoàn:</span> <%= @current_period.division_public_rate %>%</div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- 2. Mở kỳ mới -->
  <% if @current_period.nil? && can?(:create, Period) %>
    <div class="bg-white rounded-lg shadow border border-gray-200 p-6">
      <h2 class="text-lg font-semibold mb-4">Mở kỳ mới</h2>

      <% if @latest_period %>
        <%# Đã có kỳ trước → kỳ mới = previous + 1 tháng (tự động, không cho sửa). %>
        <div class="bg-blue-50 border border-blue-200 rounded p-3 mb-4 text-sm text-blue-900">
          Kỳ mới sẽ là <strong>Tháng <%= @next_month %>/<%= @next_year %></strong>
          (kế tiếp kỳ tháng <%= @latest_period.month %>/<%= @latest_period.year %>).
          Hệ thống tự kế thừa đơn giá, các tỷ lệ và phân bổ bơm nước từ kỳ trước.
          Bạn có thể chỉnh các giá trị này sau khi mở kỳ.
        </div>
        <%= form_with url: open_period_pricing_path, method: :post, local: true,
              data: { turbo_confirm: "Mở kỳ tháng #{@next_month}/#{@next_year}?" } do %>
          <%= submit_tag "Mở kỳ tháng #{@next_month}/#{@next_year}",
                class: "bg-green-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-700 cursor-pointer" %>
        <% end %>
      <% else %>
        <%# Kỳ đầu tiên — cần nhập đầy đủ. %>
        <p class="text-sm text-gray-600 mb-4">
          Đây là kỳ đầu tiên của hệ thống. Vui lòng nhập đầy đủ năm, tháng và đơn giá.
        </p>
        <%= form_with url: open_period_pricing_path, method: :post, local: true, class: "space-y-3" do %>
          <div class="grid grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Năm</label>
              <%= number_field_tag :year, Date.current.year,
                  class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tháng</label>
              <%= number_field_tag :month, Date.current.month,
                  class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Đơn giá (đồng/kWh)</label>
              <%= number_field_tag :unit_price, "", step: "0.01",
                  class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
            </div>
          </div>
          <%= submit_tag "Mở kỳ mới",
                class: "bg-green-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-700 cursor-pointer" %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- 3. Danh sách các kỳ -->
  <%= render "shared/list_toolbar",
        url: pricing_path,
        total_count: @total_count,
        show_search: false,
        per_page_storage_key: "pricing_per_page",
        filters: [
          { label: "Năm:", param: :year,
            options: @available_years.map { |y| [y, y] }, selected: @selected_year }
        ] %>

  <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Kỳ</th>
          <th class="px-4 py-2 text-right text-xs font-semibold text-gray-600 uppercase">Đơn giá</th>
          <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Trạng thái</th>
          <th class="px-4 py-2 text-right text-xs font-semibold text-gray-600 uppercase">Thao tác</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @all_periods.each do |p| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-2 text-sm text-gray-900">Tháng <%= p.month %>/<%= p.year %></td>
            <td class="px-4 py-2 text-sm text-right text-gray-600"><%= unit_price_to_vi(p.unit_price) %> đ/kW</td>
            <td class="px-4 py-2 text-sm">
              <% if p.open? %>
                <span class="text-green-700 bg-green-100 px-2 py-1 rounded text-xs">Đang mở</span>
              <% else %>
                <span class="text-gray-700 bg-gray-100 px-2 py-1 rounded text-xs">Đã đóng</span>
              <% end %>
            </td>
            <td class="px-4 py-2 text-sm text-right">
              <% if !p.open? && @current_period.nil? && can?(:update, p) %>
                <%= button_to "Mở lại", reopen_period_pricing_path, method: :post,
                    params: { period_id: p.id },
                    form: { class: "inline", data: { turbo_confirm: "Mở lại kỳ tháng #{p.month}/#{p.year}?" } },
                    class: "text-blue-600 hover:text-blue-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @pagy.pages > 1 %>
      <div class="p-4 border-t border-gray-200">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>
</div>
