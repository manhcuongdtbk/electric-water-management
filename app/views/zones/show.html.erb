<% content_for :title, @zone.name %>

<div class="max-w-2xl">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to zones_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-xl font-semibold text-gray-900"><%= @zone.name %></h1>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100 mb-6">
    <div class="flex px-5 py-3 text-sm">
      <span class="w-40 text-gray-500 flex-shrink-0"><%= t("zones.form.name") %></span>
      <span class="text-gray-900 font-medium"><%= @zone.name %></span>
    </div>
    <div class="flex px-5 py-3 text-sm">
      <span class="w-40 text-gray-500 flex-shrink-0"><%= t("zones.form.manager_organization") %></span>
      <span class="text-gray-900"><%= @zone.manager_organization&.name || t("zones.show.no_manager") %></span>
    </div>
  </div>

  <%# Công tơ tổng %>
  <div class="mb-6">
    <div class="flex items-center justify-between mb-2">
      <div>
        <h2 class="text-base font-semibold text-gray-900"><%= t("zones.show.main_meters_section") %></h2>
        <p class="text-xs text-gray-500"><%= t("zones.show.main_meters_hint") %></p>
      </div>
      <% if can? :create, MainMeter %>
        <%= link_to t("zones.show.add_main_meter"), new_zone_main_meter_path(@zone),
              class: "inline-flex items-center gap-1.5 rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors" %>
      <% end %>
    </div>

    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left font-medium text-gray-600 w-12"><%= t("main_meters.columns.stt") %></th>
            <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("main_meters.columns.name") %></th>
            <th class="px-4 py-3 text-left font-medium text-gray-600 w-32"><%= t("main_meters.columns.actions") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if @main_meters.any? %>
            <% @main_meters.each_with_index do |main_meter, idx| %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 text-gray-500"><%= idx + 1 %></td>
                <td class="px-4 py-3 font-medium text-gray-900"><%= main_meter.name %></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <% if can? :update, main_meter %>
                      <%= link_to t("main_meters.actions.edit"), edit_zone_main_meter_path(@zone, main_meter),
                            class: "text-blue-600 hover:underline text-xs" %>
                    <% end %>
                    <% if can? :destroy, main_meter %>
                      <%= button_to t("main_meters.actions.delete"), zone_main_meter_path(@zone, main_meter),
                            method: :delete,
                            data: { turbo_confirm: t("main_meters.actions.delete_confirm") },
                            class: "text-red-600 hover:underline text-xs bg-transparent border-0 cursor-pointer p-0" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="px-4 py-6 text-center text-gray-500 italic">
                <%= t("zones.show.main_meters_empty") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Đơn vị thuộc khu vực %>
  <div class="mb-6">
    <h2 class="text-base font-semibold text-gray-900 mb-2"><%= t("zones.show.organizations_section") %></h2>
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <% if @organizations.any? %>
        <ul class="divide-y divide-gray-100">
          <% @organizations.each do |organization| %>
            <li class="px-5 py-3 text-sm text-gray-900"><%= organization.name %></li>
          <% end %>
        </ul>
      <% else %>
        <p class="px-5 py-6 text-center text-sm text-gray-500 italic"><%= t("zones.show.organizations_empty") %></p>
      <% end %>
    </div>
  </div>

  <div class="flex gap-3">
    <% if can? :update, @zone %>
      <%= link_to t("zones.actions.edit"), edit_zone_path(@zone),
            class: "px-4 py-2 bg-amber-500 text-white text-sm font-medium rounded-md hover:bg-amber-600 transition-colors" %>
    <% end %>
    <% if can? :destroy, @zone %>
      <%= button_to t("zones.actions.delete"), zone_path(@zone),
            method: :delete,
            data: { turbo_confirm: t("zones.actions.delete_confirm") },
            class: "px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-700 transition-colors cursor-pointer border-0" %>
    <% end %>
    <%= link_to t("zones.show.back"), zones_path,
          class: "px-4 py-2 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50 transition-colors" %>
  </div>
</div>
