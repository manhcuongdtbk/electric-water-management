<% page_title t("sidebar.items.zones") %>


<%
  add_link = can?(:create, Zone) ?
    link_to(t("common.actions.add") + " " + t("resources.zone"), new_zone_path,
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700") : nil
%>

<%= render "shared/list_toolbar",
      url: zones_path,
      search_placeholder: "Tìm theo tên khu vực...",
      total_count: @total_count,
      add_link: add_link,
      per_page_storage_key: "zones_per_page" %>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <%= sortable_header :name, "Khu vực",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page] } %>
        <%= sortable_header :units_count, "Số đơn vị",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page] } %>
        <%= sortable_header :manager_unit, t("activerecord.attributes.zone.manager_unit"),
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page] } %>
        <%= list_header t("resources.main_meter").humanize %>
        <%= list_header t("common.list.actions"), align: :right %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @zones.empty? %>
        <tr><td colspan="5" class="px-4 py-6 text-center text-gray-500"><%= t("common.list.no_records") %></td></tr>
      <% end %>
      <% @zones.each do |zone| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-2 text-sm font-medium text-gray-900"><%= zone.name %></td>
          <%
            kept_units = zone.units.reject(&:discarded?)
            kept_main_meters = zone.main_meters.reject(&:discarded?)
          %>
          <td class="px-4 py-2 text-sm text-gray-600"><%= kept_units.size %></td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= zone.manager_unit&.name || "—" %></td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <%= kept_main_meters.any? ? kept_main_meters.map(&:name).join(", ") : "—" %>
          </td>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if can?(:update, zone) || can?(:destroy, zone) %>
              <% if can?(:update, zone) %>
                <%= link_to t("common.actions.edit"), edit_zone_path(zone),
                      class: "text-blue-600 hover:text-blue-800" %>
              <% end %>
              <% if can?(:destroy, zone) %>
                <%= button_to t("common.actions.destroy"), zone_path(zone), method: :delete,
                      form: { class: "inline", data: { turbo_confirm: t("common.confirm.destroy_named", name: zone.name) } },
                      class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
              <% end %>
            <% else %>
              <%= empty_actions_dash %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
