<% content_for :title, t("work_groups.index.title") %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-xl font-semibold text-gray-900"><%= t("work_groups.index.title") %></h1>
  <%= link_to t("work_groups.index.new_button"), new_work_group_path,
        class: "inline-flex items-center gap-1.5 rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors" %>
</div>

<p class="mb-4 text-sm text-gray-600"><%= t("work_groups.index.subtitle") %></p>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left font-medium text-gray-600 w-10"><%= t("work_groups.index.columns.stt") %></th>
        <% if can? :manage, :all %>
          <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("activerecord.attributes.work_group.owner_organization") %></th>
        <% end %>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("work_groups.index.columns.name") %></th>
        <th class="px-4 py-3 text-right font-medium text-gray-600 w-32"><%= t("work_groups.index.columns.personnel_count") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("work_groups.index.columns.notes") %></th>
        <th class="px-4 py-3 text-right font-medium text-gray-600 w-20"><%= t("work_groups.index.columns.position") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600 w-32"><%= t("work_groups.index.columns.actions") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @work_groups.any? %>
        <% @work_groups.each_with_index do |wg, idx| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-500"><%= idx + 1 %></td>
            <% if can? :manage, :all %>
              <td class="px-4 py-3 text-gray-700"><%= wg.owner_organization.name %></td>
            <% end %>
            <td class="px-4 py-3 font-medium text-gray-900"><%= wg.name %></td>
            <td class="px-4 py-3 text-right text-gray-700"><%= number_with_delimiter(wg.personnel_count) %></td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= wg.notes.presence || "—" %></td>
            <td class="px-4 py-3 text-right text-gray-700"><%= wg.position %></td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <%= link_to t("work_groups.actions.edit"), edit_work_group_path(wg),
                      class: "text-blue-600 hover:underline text-xs" %>
                <%= button_to t("work_groups.actions.delete"), work_group_path(wg),
                      method: :delete,
                      data: { turbo_confirm: t("work_groups.actions.delete_confirm") },
                      class: "text-red-600 hover:underline text-xs bg-transparent border-0 cursor-pointer p-0" %>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="<%= can?(:manage, :all) ? 7 : 6 %>" class="px-4 py-6 text-center text-gray-500 italic">
            <%= t("work_groups.index.empty") %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
