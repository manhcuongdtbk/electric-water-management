<%= form_with model: work_group do |f| %>
  <% if work_group.errors.any? %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
      <ul class="list-disc pl-4 space-y-0.5">
        <% work_group.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4 max-w-2xl">
    <div>
      <%= f.label :name, t("work_groups.form.name"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
            required: true %>
    </div>

    <div>
      <%= f.label :personnel_count, t("work_groups.form.personnel_count"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :personnel_count,
            class: "block w-32 rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
            min: 0, required: true %>
      <p class="mt-1 text-xs text-gray-500"><%= t("work_groups.form.personnel_count_hint") %></p>
    </div>

    <div>
      <%= f.label :notes, t("work_groups.form.notes"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :notes, rows: 2,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :position, t("work_groups.form.position"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :position,
            class: "block w-32 rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
            min: 0 %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit work_group.new_record? ? t("work_groups.form.submit_create") : t("work_groups.form.submit_update"),
            class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors cursor-pointer" %>
      <%= link_to t("work_groups.form.cancel"), work_groups_path,
            class: "text-sm text-gray-600 hover:underline" %>
    </div>
  </div>
<% end %>
