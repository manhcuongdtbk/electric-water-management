<% available_units = Unit.kept.accessible_by(current_ability) %>
<% available_blocks = Block.kept.accessible_by(current_ability).order(:name) %>

<%= form_with model: group, local: true, class: "space-y-4",
      data: { controller: "scoped-block-select" } do |f| %>
  <% if group.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
      <ul class="list-disc list-inside">
        <% group.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Tên nhóm", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
        class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
  </div>

  <div>
    <%= f.label :unit_id, "Đơn vị", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :unit_id, available_units.order(:name).pluck(:name, :id),
        { include_blank: "— Chọn đơn vị —" },
        class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm",
        data: { scoped_block_select_target: "unitSelect",
                action: "change->scoped-block-select#refresh" } %>
  </div>

  <div>
    <%= f.label :block_id, "Khối (tùy chọn)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :block_id,
        available_blocks.map { |b| [b.name, b.id, { "data-unit-id": b.unit_id }] },
        { include_blank: "— Không thuộc khối —" },
        class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm",
        data: { scoped_block_select_target: "blockSelect" } %>
  </div>

  <div class="flex space-x-2">
    <%= f.submit "Lưu", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Hủy", groups_path, class: "text-gray-600 px-4 py-2 hover:text-gray-800" %>
  </div>
<% end %>
