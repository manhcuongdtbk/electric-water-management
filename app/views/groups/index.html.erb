<% page_title "Nhóm" %>

<div class="flex justify-between items-center mb-4">
  <%= form_with url: groups_path, method: :get, local: true, class: "flex space-x-2" do %>
    <%= text_field_tag :q, params[:q], placeholder: "Tìm theo tên...",
        class: "rounded border border-gray-300 px-3 py-2 text-sm" %>
    <%= submit_tag "Tìm", class: "bg-gray-100 text-gray-700 px-4 py-2 rounded text-sm font-medium hover:bg-gray-200 cursor-pointer" %>
  <% end %>
  <% if can?(:create, Group) %>
    <%= link_to "Thêm nhóm", new_group_path,
        class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700" %>
  <% end %>
</div>

<div class="text-sm text-gray-600 mb-2">Tổng số: <strong><%= @total_count %></strong></div>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Tên</th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Đơn vị</th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase">Khối</th>
        <th class="px-4 py-2 text-right text-xs font-semibold text-gray-600 uppercase">Thao tác</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @groups.each do |g| %>
        <tr>
          <td class="px-4 py-2 text-sm font-medium text-gray-900"><%= g.name %></td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= g.unit&.name %></td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= g.block&.name || "—" %></td>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if can?(:update, g) %>
              <%= link_to "Sửa", edit_group_path(g), class: "text-blue-600 hover:text-blue-800" %>
            <% end %>
            <% if can?(:destroy, g) %>
              <%= button_to "Xóa", group_path(g), method: :delete,
                  form: { data: { turbo_confirm: "Xác nhận xóa nhóm \"#{g.name}\"?" } },
                  class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
