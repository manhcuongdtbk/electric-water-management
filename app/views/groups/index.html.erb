<% page_title t("sidebar.items.groups") %>


<%
  add_link = can?(:create, Group) ?
    link_to(t("common.actions.add") + " " + t("resources.group"), new_group_path,
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700") : nil

  show_zone_unit = current_user.system_admin?

  toolbar_filters = []
  if show_zone_unit
    toolbar_filters = [
      { label: "Khu vực:", param: :zone_id,
        options: @available_zones.pluck(:name, :id), selected: @zone&.id,
        children: [:unit_id] },
      { label: "Đơn vị:", param: :unit_id,
        options: @available_units.pluck(:name, :id), selected: @unit&.id }
    ]
  end
  extra_sort_params = { q: params[:q], per_page: params[:per_page],
                        zone_id: params[:zone_id], unit_id: params[:unit_id] }
%>

<%= render "shared/list_toolbar",
      url: groups_path,
      search_placeholder: "Tìm theo tên nhóm...",
      total_count: @total_count,
      add_link: add_link,
      per_page_storage_key: "groups_per_page",
      filters: toolbar_filters %>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <%= sortable_header :name, "Nhóm",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: extra_sort_params %>
        <%= sortable_header :block, "Khối",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: extra_sort_params %>
        <% if show_zone_unit %>
          <%= sortable_header :unit, "Đơn vị",
                current_sort: params[:sort], current_dir: params[:dir],
                extra_params: extra_sort_params %>
          <%= sortable_header :zone, "Khu vực",
                current_sort: params[:sort], current_dir: params[:dir],
                extra_params: extra_sort_params %>
        <% end %>
        <%= list_header t("common.list.actions"), align: :right %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @groups.empty? %>
        <tr><td colspan="<%= show_zone_unit ? 5 : 3 %>" class="px-4 py-6 text-center text-gray-500"><%= t("common.list.no_records") %></td></tr>
      <% end %>
      <% @groups.each do |g| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-2 text-sm font-medium text-gray-900"><%= g.name %></td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= g.block&.name || "—" %></td>
          <% if show_zone_unit %>
            <td class="px-4 py-2 text-sm text-gray-600"><%= g.unit&.name %></td>
            <td class="px-4 py-2 text-sm text-gray-600"><%= g.unit&.zone&.name %></td>
          <% end %>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if can?(:update, g) || can?(:destroy, g) %>
              <% if can?(:update, g) %>
                <%= link_to t("common.actions.edit"), edit_group_path(g),
                      class: "text-blue-600 hover:text-blue-800" %>
              <% end %>
              <% if can?(:destroy, g) %>
                <%= button_to t("common.actions.destroy"), group_path(g), method: :delete,
                      form: { class: "inline", data: { turbo_confirm: t("common.confirm.destroy_named", name: g.name) } },
                      class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
              <% end %>
            <% else %>
              <%= empty_actions_dash %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
