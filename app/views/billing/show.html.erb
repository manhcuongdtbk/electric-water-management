<% page_title "Bảng tính tiền" %>

<% if @period.nil? %>
  <div class="bg-yellow-50 border border-yellow-200 rounded p-6 text-yellow-900">
    <%= t("flash.no_open_period") %>
  </div>
<% else %>
  <%
    billing_filters = [
      { label: "Kỳ:", param: :period_id,
        options: @available_periods.map { |p| ["Tháng #{p.month}/#{p.year}", p.id] },
        selected: @period.id }
    ]
    if current_user.system_admin?
      billing_filters += [
        { label: "Khu vực:", param: :zone_id,
          options: @available_zones.map { |z| [z.name, z.id] }, selected: @zone&.id,
          children: [:unit_id] },
        { label: "Đơn vị:", param: :unit_id,
          options: @available_units.map { |u| [u.name, u.id] }, selected: @unit&.id }
      ]
    end

    billing_action_links = capture do
      if @period.open? && can?(:recalculate, Calculation)
        concat(button_to("Tính toán lại", recalculate_billing_path(billing_filter_params),
          method: :post,
          form: { data: {
            turbo_confirm: "Xác nhận tính toán lại bảng tính tiền?",
            controller: "submit-loading",
            submit_loading_loading_text_value: t("billing.buttons.recalculating")
          } },
          class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700"))
      end
      if can?(:read, Calculation)
        export_url = billing_path(billing_filter_params.merge(format: :xlsx))
        concat(link_to("Xuất Excel", export_url,
          data: {
            controller: "stale-export",
            action: "stale-export#confirm",
            "stale-export-stale-value": @freshness_states.any? { |entry| entry.status == :stale },
            "stale-export-message-value": t("billing.export.stale_confirm"),
            "stale-export-url-value": export_url
          },
          class: "bg-green-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-700"))
      end
    end
  %>

  <%= render "shared/list_toolbar",
        url: billing_path,
        total_count: @total_count,
        filters: billing_filters,
        show_search: false,
        show_per_page: false,
        total_label: "Tổng: #{@total_count} đầu mối",
        action_links: billing_action_links %>

  <%= render "warnings" %>

  <%= render "shared/freshness_indicator", states: @freshness_states %>

  <p class="text-sm text-gray-700 mb-2">
    Đơn giá điện: <strong><%= unit_price_to_vi(@period.unit_price) %> đ/kW</strong>
    <% unless @period.open? %>
      <span class="ml-2 px-2 py-0.5 rounded bg-gray-200 text-gray-700 text-xs">Đã đóng</span>
    <% end %>
  </p>

  <div class="-mx-6">
    <div class="overflow-x-auto px-6 max-h-[70vh] overflow-y-auto"
         data-controller="column-resize"
         data-column-resize-storage-key-value="billing-<%= current_user.role %>-<%= billing_column_signature(show_zone: @show_zone_column, show_unit: @show_unit_column) %>">
      <%= render "table" %>
    </div>
  </div>

  <% if @pagy && @pagy.pages > 1 %>
    <div class="mt-4"><%== pagy_nav(@pagy) %></div>
  <% end %>

  <%= render "reconciliation_sections" %>
<% end %>
