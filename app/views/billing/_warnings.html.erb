<% if @warnings.present? %>
  <div class="bg-yellow-50 border border-yellow-300 text-yellow-900 rounded p-3 mb-3 text-sm">
    <p class="font-semibold mb-1">Cảnh báo dữ liệu:</p>
    <ul class="list-disc list-inside space-y-1">
      <% @warnings.each do |w| %>
        <li><%= w %></li>
      <% end %>
    </ul>
  </div>
<% end %>
