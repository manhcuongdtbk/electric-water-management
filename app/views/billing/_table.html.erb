<%
  cell        = "border border-gray-300 px-2 py-1 text-xs"
  num_cell    = "#{cell} text-right whitespace-nowrap"
  text_cell   = "#{cell} whitespace-nowrap"
  rowspans    = compute_rowspans(@calculations, show_zone: @show_zone_column, show_unit: @show_unit_column)
  empty_state_colspan = (@show_zone_column ? 1 : 0) + (@show_unit_column ? 1 : 0) + 3 + @ranks.size + 1 + 3 + 6 + 1 + 3 + 4
%>
<table class="border-collapse w-full text-xs" data-billing-table>
  <thead class="sticky top-0 z-10">
    <%= render "billing/table_header" %>
  </thead>
  <tbody>
    <% if @calculations.empty? %>
      <tr>
        <td colspan="<%= empty_state_colspan %>" class="<%= cell %> text-center text-gray-500 py-6">
          Chưa có dữ liệu tính toán. Bấm "Tính toán lại" để tính toán kỳ này.
        </td>
      </tr>
    <% else %>
      <% @calculations.each_with_index do |calc, i| %>
        <% cp = calc.contact_point %>
        <tr class="hover:bg-yellow-50">
          <% if @show_zone_column && (rs = rowspans[i][:zone]) %>
            <td rowspan="<%= rs %>" class="<%= text_cell %>"><%= cp.effective_zone&.name %></td>
          <% end %>
          <% if @show_unit_column && (rs = rowspans[i][:unit]) %>
            <td rowspan="<%= rs %>" class="<%= text_cell %>"><%= cp.unit&.name %></td>
          <% end %>
          <% if (rs = rowspans[i][:block]) %>
            <td rowspan="<%= rs %>" class="<%= text_cell %>"><%= cp.block&.name %></td>
          <% end %>
          <% if (rs = rowspans[i][:group]) %>
            <td rowspan="<%= rs %>" class="<%= text_cell %>"><%= cp.group&.name %></td>
          <% end %>
          <td class="<%= text_cell %>" data-contact-point-name-id="<%= cp.id %>"><%= cp.name %></td>
          <% @ranks.each do |rank| %>
            <td class="<%= num_cell %>"><%= (@personnel_by_cp_id[cp.id] || {})[rank.id] || 0 %></td>
          <% end %>
          <td class="<%= num_cell %>"><%= calc.total_personnel %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.residential_standard) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.water_pump_standard) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.total_standard) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.savings_deduction) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.loss_deduction) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.division_public_deduction) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.unit_public_deduction) %></td>
          <td class="<%= num_cell %>" data-other-deduction-cp-id="<%= cp.id %>"><%= number_to_vi(calc.other_deduction) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.total_deduction) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.remaining_standard) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.residential_usage) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.water_pump_usage) %></td>
          <td class="<%= num_cell %>"><%= number_to_vi(calc.total_usage) %></td>
          <td class="<%= num_cell %> text-green-700"><%= calc.surplus > 0 ? number_to_vi(calc.surplus) : "" %></td>
          <td class="<%= num_cell %> text-red-700"><%= calc.deficit > 0 ? number_to_vi(calc.deficit) : "" %></td>
          <td class="<%= num_cell %> text-green-700"><%= calc.surplus_amount > 0 ? money_to_vi_plain(calc.surplus_amount) : "" %></td>
          <td class="<%= num_cell %> text-red-700"><%= calc.deficit_amount > 0 ? money_to_vi_plain(calc.deficit_amount) : "" %></td>
        </tr>
      <% end %>
      <%= render "billing/summary_row" %>
    <% end %>
  </tbody>
</table>
