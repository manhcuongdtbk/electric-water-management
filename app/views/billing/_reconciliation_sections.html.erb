<% if @reconciliation_zones.any? %>
  <div class="mt-6 space-y-3">
    <% single_zone = @reconciliation_zones.size == 1 %>
    <% @reconciliation_zones.each do |zone| %>
      <% pump_matrix = @pump_station_matrices[zone.id] %>
      <% loss_breakdown = @loss_breakdowns[zone.id] %>
      <% loss_summary = @loss_summaries.find { |s| s.zone_id == zone.id } %>
      <% next unless pump_matrix || loss_breakdown %>

      <details class="border border-gray-200 rounded-lg" <%= "open" if single_zone %>>
        <summary class="px-4 py-3 bg-gray-50 cursor-pointer text-sm font-semibold text-gray-700 hover:bg-gray-100 rounded-t-lg">
          <%= t("billing.reconciliation.section_title", zone: zone.name) %>
        </summary>
        <div class="p-4 space-y-4">
          <% if pump_matrix %>
            <div class="overflow-x-auto">
              <table class="text-sm border border-gray-200" data-pump-station-table>
                <caption class="text-left font-semibold text-gray-700 px-2 py-1">
                  <%= t("billing.pump_station_breakdown.title") %>
                </caption>
                <thead class="bg-gray-100 text-gray-700">
                  <tr>
                    <th class="px-2 py-1 text-left"><%= t("billing.pump_station_breakdown.columns.recipient") %></th>
                    <% grand = pump_matrix.grand_total %>
                    <% pump_matrix.stations.each do |station| %>
                      <% share = grand.zero? ? nil : pump_matrix.station_total(station) * BigDecimal("100") / grand %>
                      <th class="px-2 py-1 text-right">
                        <div><%= station.name %></div>
                        <div class="font-normal text-gray-500"
                             data-pump-station-zone-share="<%= station.id %>">
                          <%= t("billing.pump_station_breakdown.station_zone_share",
                                percent: pump_zone_share_percent(share)) %>
                        </div>
                      </th>
                    <% end %>
                    <th class="px-2 py-1 text-right"><%= t("billing.pump_station_breakdown.columns.total") %></th>
                  </tr>
                </thead>
                <tbody>
                  <% pump_matrix.recipients.each do |recipient| %>
                    <tr data-pump-charge-row="<%= recipient.id %>">
                      <td class="px-2 py-1">
                        <div class="font-medium text-gray-900"><%= recipient.name %></div>
                        <% recipient_path = [recipient.unit&.name, recipient.block&.name, recipient.group&.name].compact %>
                        <% if recipient_path.any? %>
                          <div class="text-xs text-gray-400"><%= recipient_path.join(" › ") %></div>
                        <% end %>
                      </td>
                      <% pump_matrix.stations.each do |station| %>
                        <% amount = pump_matrix.amount_for(recipient, station) %>
                        <td class="px-2 py-1 text-right <%= "text-gray-400" if amount.zero? %>"
                            data-pump-charge-cell="<%= recipient.id %>-<%= station.id %>">
                          <%= number_to_vi(amount) %>
                        </td>
                      <% end %>
                      <td class="px-2 py-1 text-right font-medium"
                          data-pump-charge-total="<%= recipient.id %>">
                        <%= number_to_vi(pump_matrix.stations.sum { |station| pump_matrix.amount_for(recipient, station) }) %><span class="text-blue-500">*</span>
                      </td>
                    </tr>
                  <% end %>
                  <tr class="font-semibold border-t border-gray-300">
                    <td class="px-2 py-1"><%= t("billing.pump_station_breakdown.rows.grand_total") %></td>
                    <% pump_matrix.stations.each do |station| %>
                      <td class="px-2 py-1 text-right"><%= number_to_vi(pump_matrix.station_total(station)) %></td>
                    <% end %>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(pump_matrix.grand_total) %></td>
                  </tr>
                </tbody>
              </table>
              <ul class="mt-1 text-xs text-gray-500 list-disc pl-5 space-y-0.5">
                <% t("billing.pump_station_breakdown.note_items").each do |item| %>
                  <li><%= item %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <% if loss_breakdown && loss_summary %>
            <div class="overflow-x-auto">
              <table class="text-sm border border-gray-200">
                <caption class="text-left font-semibold text-gray-700 px-2 py-1">
                  <%= t("billing.loss_breakdown.title") %>
                </caption>
                <thead class="bg-gray-100 text-gray-700">
                  <tr>
                    <th class="px-2 py-1 text-left"><%= t("billing.loss_breakdown.columns.type") %></th>
                    <th class="px-2 py-1 text-right"><%= t("billing.loss_breakdown.columns.usage") %></th>
                    <th class="px-2 py-1 text-right"><%= t("billing.loss_breakdown.columns.loss") %></th>
                    <th class="px-2 py-1 text-right"><%= t("billing.loss_breakdown.columns.actual") %></th>
                  </tr>
                </thead>
                <tbody>
                  <% loss_breakdown.rows.each do |row| %>
                    <tr>
                      <td class="px-2 py-1"><%= t("activerecord.attributes.contact_point.types.#{row.type}", default: row.type) %></td>
                      <td class="px-2 py-1 text-right"><%= number_to_vi(row.usage) %></td>
                      <td class="px-2 py-1 text-right"><%= number_to_vi(row.loss) %><%= '<span class="text-blue-500">*</span>'.html_safe if row.type == "residential" %></td>
                      <td class="px-2 py-1 text-right"><%= number_to_vi(row.actual) %></td>
                    </tr>
                  <% end %>
                  <tr class="font-semibold border-t border-gray-300">
                    <td class="px-2 py-1"><%= t("billing.loss_breakdown.rows.loss_bearing_total") %></td>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(loss_breakdown.loss_bearing_total.usage) %> <span class="font-normal text-gray-400">(B)</span></td>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(loss_breakdown.loss_bearing_total.loss) %> <span class="font-normal text-gray-400">(C)</span></td>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(loss_breakdown.loss_bearing_total.actual) %> <span class="font-normal text-gray-400">(A)</span></td>
                  </tr>
                  <tr>
                    <td class="px-2 py-1"><%= t("billing.loss_breakdown.rows.no_loss") %></td>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(loss_breakdown.no_loss_total.usage) %></td>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(loss_breakdown.no_loss_total.loss) %></td>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(loss_breakdown.no_loss_total.actual) %></td>
                  </tr>
                  <tr class="font-semibold border-t border-gray-300">
                    <td class="px-2 py-1"><%= t("billing.loss_breakdown.rows.grand_total") %></td>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(loss_breakdown.grand_total.usage) %><span class="text-blue-500">*</span></td>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(loss_breakdown.grand_total.loss) %><span class="text-blue-500">*</span></td>
                    <td class="px-2 py-1 text-right"><%= number_to_vi(loss_breakdown.grand_total.actual) %><span class="text-blue-500">*</span></td>
                  </tr>
                </tbody>
              </table>
              <ul class="mt-1 text-xs text-gray-500 list-disc pl-5 space-y-0.5">
                <% t("billing.loss_breakdown.note_items").each do |item| %>
                  <li><%= item %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
<% end %>
