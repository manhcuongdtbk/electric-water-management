<% if current_user.role == "system_admin" %>
  <%= form_with url: billing_path, method: :get, local: true,
        class: "flex gap-2 items-end",
        data: { controller: "auto-submit" } do %>
    <%= hidden_field_tag :period_id, @period.id %>
    <div>
      <label class="block text-xs text-gray-600 mb-1">Khu vực</label>
      <%= select_tag :zone_id,
            options_from_collection_for_select(@available_zones, :id, :name, @zone&.id),
            include_blank: "Tất cả khu vực",
            data: { action: "change->auto-submit#submit" },
            class: "rounded border border-gray-300 text-sm" %>
    </div>
    <div>
      <label class="block text-xs text-gray-600 mb-1">Đơn vị</label>
      <%= select_tag :unit_id,
            options_from_collection_for_select(@available_units, :id, :name, @unit&.id),
            include_blank: "Tất cả đơn vị",
            data: { action: "change->auto-submit#submit" },
            class: "rounded border border-gray-300 text-sm" %>
    </div>
  <% end %>
<% else %>
  <div class="flex gap-2 items-end text-sm text-gray-600">
    <% if @zone %>
      <div>
        <span class="block text-xs text-gray-500">Khu vực</span>
        <span class="font-medium text-gray-800"><%= @zone.name %></span>
      </div>
    <% end %>
    <% if @unit %>
      <div>
        <span class="block text-xs text-gray-500">Đơn vị</span>
        <span class="font-medium text-gray-800"><%= @unit.name %></span>
      </div>
    <% end %>
  </div>
<% end %>
