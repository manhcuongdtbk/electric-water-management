<% page_title t("sidebar.items.ranks") %>

<%= render "shared/period_indicator", period: @period %>

<%
  add_link = (@period&.open? && can?(:create, Rank)) ?
    link_to(t("common.actions.add") + " " + t("resources.rank"), new_rank_path,
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700") : nil
%>

<%= render "shared/list_toolbar",
      url: ranks_path,
      search_placeholder: "Tìm theo tên nhóm cấp bậc...",
      total_count: @total_count,
      add_link: add_link,
      per_page_storage_key: "ranks_per_page" %>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <%= sortable_header :position, "#",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page] } %>
        <%= sortable_header :name, "Nhóm cấp bậc",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page] } %>
        <%= sortable_header :quota, "Định mức (kWh/người)",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page] }, align: :right %>
        <%= list_header t("common.list.actions"), align: :right %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @ranks.empty? %>
        <tr><td colspan="4" class="px-4 py-6 text-center text-gray-500"><%= t("common.list.no_records") %></td></tr>
      <% end %>
      <% @ranks.each do |rank| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-2 text-sm text-gray-900"><%= rank.position %></td>
          <td class="px-4 py-2 text-sm font-medium text-gray-900"><%= rank.name %></td>
          <td class="px-4 py-2 text-sm text-right text-gray-600"><%= number_to_vi(rank.quota) %></td>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if @period&.open? && (can?(:update, rank) || can?(:destroy, rank)) %>
              <% if can?(:update, rank) %>
                <%= link_to t("common.actions.edit"), edit_rank_path(rank),
                      class: "text-blue-600 hover:text-blue-800" %>
              <% end %>
              <% if can?(:destroy, rank) %>
                <%= button_to t("common.actions.destroy"), rank_path(rank), method: :delete,
                      form: { class: "inline", data: { turbo_confirm: t("common.confirm.destroy_named", name: rank.name) } },
                      class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
              <% end %>
            <% else %>
              <%= empty_actions_dash %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
