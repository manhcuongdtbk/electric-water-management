<%= form_with model: rank, local: true, class: "space-y-4" do |f| %>
  <% if rank.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
      <ul class="list-disc list-inside">
        <% rank.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Tên nhóm cấp bậc", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, required: true,
        class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :quota, "Định mức (kWh/người)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :quota, step: "0.01", min: "0.01", required: true,
          class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :position, "Thứ tự", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :position, min: 1, required: true,
          class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
    </div>
  </div>

  <div class="flex space-x-2">
    <%= f.submit "Lưu", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Hủy", ranks_path, class: "text-gray-600 px-4 py-2 hover:text-gray-800" %>
  </div>
<% end %>
