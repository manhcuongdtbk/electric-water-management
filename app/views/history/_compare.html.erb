<% if @available_periods.size < 2 %>
  <div class="bg-yellow-50 border border-yellow-300 text-yellow-900 rounded p-4">
    <%= t("history.compare.need_at_least_two", count: @available_periods.size) %>
  </div>
<% else %>
  <%
    period_options = @available_periods.map { |p| [period_label(p), p.id] }
    toolbar_filters = [
      { label: t("history.compare.period_a"), param: :period_a,
        options: period_options, selected: @period_a&.id,
        blank_text: "-- #{t('history.compare.select')} --" },
      { label: t("history.compare.period_b"), param: :period_b,
        options: period_options, selected: @period_b&.id,
        blank_text: "-- #{t('history.compare.select')} --" }
    ]
  %>
  <%= render "shared/list_toolbar",
       url: history_path(mode: "compare"),
       total_count: @comparison&.size || 0,
       filters: toolbar_filters,
       extra_hidden: { mode: "compare" },
       show_search: false,
       show_per_page: false,
       show_total: @comparison.present? %>

  <% if @comparison.nil? %>
  <% elsif @comparison.empty? %>
    <div class="bg-gray-50 border border-gray-200 rounded p-4 text-gray-600">
      <%= t("history.compare.no_data") %>
    </div>
  <% else %>
    <%
      a_label = "#{@period_a.month}/#{@period_a.year}"
      b_label = "#{@period_b.month}/#{@period_b.year}"

      # Đơn giá 2 kỳ
      price_a = @period_a.unit_price
      price_b = @period_b.unit_price

      # Styling
      cell      = "border border-gray-300 px-2 py-1 text-xs"
      num_cell  = "#{cell} text-right whitespace-nowrap"
      text_cell = "#{cell} whitespace-nowrap"
      header_cell = "#{cell} bg-gray-50 font-semibold text-center"
      empty_mark = '<span class="text-gray-400">—</span>'.html_safe

      # Metric groups — nhóm giống billing (3-row header)
      metric_sections = [
        { name: "Tiêu chuẩn", metrics: [
          ["Tiêu chuẩn điện sinh hoạt", :residential_standard, :num],
          ["Tiêu chuẩn điện bơm nước", :water_pump_standard, :num],
          ["Tổng tiêu chuẩn", :total_standard, :num]
        ]},
        { name: "Khoản trừ", metrics: [
          ["Tổng trừ", :total_deduction, :num]
        ]},
        { name: "Tiêu chuẩn còn lại", metrics: [
          ["Tiêu chuẩn còn lại", :remaining_standard, :num]
        ]},
        { name: "Sử dụng", metrics: [
          ["Sử dụng điện sinh hoạt", :residential_usage, :num],
          ["Sử dụng điện bơm nước", :water_pump_usage, :num],
          ["Tổng sử dụng", :total_usage, :num]
        ]},
        { name: "Kết quả", metrics: [
          ["Thừa (kW)", :surplus, :num, :surplus],
          ["Thiếu (kW)", :deficit, :num, :deficit],
          ["Thành tiền thừa", :surplus_amount, :money, :surplus],
          ["Thành tiền thiếu", :deficit_amount, :money, :deficit]
        ]}
      ]

      all_metrics = metric_sections.flat_map { |s| s[:metrics] }

      format_value = ->(value, type) do
        return empty_mark if value.nil?
        case type
        when :int   then value.to_i.to_s
        when :money then money_to_vi_plain(value)
        else             number_to_vi(value)
        end
      end

      delta_class = ->(_attr, _value) { "" }

      # Rowspan — dùng RowspanComputer giống billing
      fake_calcs = @comparison.map do |row|
        OpenStruct.new(contact_point: row.contact_point)
      end
      rowspans = Billing::RowspanComputer.compute(fake_calcs, show_zone: true, show_unit: true)

      # Info columns count
      info_cols = 5  # Khu vực, Đơn vị, Khối, Nhóm, Tên
    %>

    <p class="text-sm text-gray-700 mb-2">
      Đơn giá điện:
      <strong><%= a_label %>: <%= unit_price_to_vi(price_a) %> đ/kW</strong>
      —
      <strong><%= b_label %>: <%= unit_price_to_vi(price_b) %> đ/kW</strong>
    </p>

    <div class="-mx-6">
      <div class="overflow-x-auto px-6 max-h-[70vh] overflow-y-auto">
        <table class="border-collapse w-full text-xs">
          <thead class="sticky top-0 z-10">
            <%# Row 1: nhóm lớn %>
            <tr>
              <th colspan="<%= info_cols %>" class="<%= header_cell %>">Thông tin đầu mối</th>
              <th colspan="3" class="<%= header_cell %>">Quân số</th>
              <% metric_sections.each do |section| %>
                <th colspan="<%= section[:metrics].size * 3 %>" class="<%= header_cell %>"><%= section[:name] %></th>
              <% end %>
              <th rowspan="3" class="<%= header_cell %>">Ghi chú</th>
            </tr>

            <%# Row 2: tên metric (hoặc A/B/Δ nếu nhóm chỉ có 1 metric) %>
            <tr>
              <th rowspan="2" class="<%= header_cell %>">Khu vực</th>
              <th rowspan="2" class="<%= header_cell %>">Đơn vị</th>
              <th rowspan="2" class="<%= header_cell %>">Khối</th>
              <th rowspan="2" class="<%= header_cell %>">Nhóm</th>
              <th rowspan="2" class="<%= header_cell %>">Tên đầu mối</th>
              <%# Quân số — 1 metric → A/B/Δ trực tiếp ở row 2, rowspan 2 %>
              <th rowspan="2" class="<%= header_cell %>"><%= a_label %></th>
              <th rowspan="2" class="<%= header_cell %>"><%= b_label %></th>
              <th rowspan="2" class="<%= header_cell %>">Δ</th>
              <% metric_sections.each do |section| %>
                <% if section[:metrics].size == 1 %>
                  <%# Nhóm 1 metric: A/B/Δ trực tiếp, rowspan 2 %>
                  <th rowspan="2" class="<%= header_cell %>"><%= a_label %></th>
                  <th rowspan="2" class="<%= header_cell %>"><%= b_label %></th>
                  <th rowspan="2" class="<%= header_cell %>">Δ</th>
                <% else %>
                  <% section[:metrics].each do |label, _attr, _type, _color| %>
                    <th colspan="3" class="<%= header_cell %>"><%= label %></th>
                  <% end %>
                <% end %>
              <% end %>
            </tr>

            <%# Row 3: A/B/Δ per metric (chỉ cho nhóm có nhiều metric) %>
            <tr>
              <% metric_sections.each do |section| %>
                <% next if section[:metrics].size == 1 %>
                <% section[:metrics].size.times do %>
                  <th class="<%= header_cell %>"><%= a_label %></th>
                  <th class="<%= header_cell %>"><%= b_label %></th>
                  <th class="<%= header_cell %>">Δ</th>
                <% end %>
              <% end %>
            </tr>
          </thead>

          <tbody>
            <% @comparison.each_with_index do |row, idx| %>
              <tr class="hover:bg-yellow-50">
                <%# Info columns with merge %>
                <% rs = rowspans[idx] %>
                <% if rs[:zone] %>
                  <td class="<%= text_cell %>" rowspan="<%= rs[:zone] %>"><%= row.contact_point&.effective_zone&.name %></td>
                <% end %>
                <% if rs[:unit] %>
                  <td class="<%= text_cell %>" rowspan="<%= rs[:unit] %>"><%= row.contact_point&.unit&.name %></td>
                <% end %>
                <% if rs[:block] %>
                  <td class="<%= text_cell %>" rowspan="<%= rs[:block] %>"><%= row.contact_point&.block&.name %></td>
                <% end %>
                <% if rs[:group] %>
                  <td class="<%= text_cell %>" rowspan="<%= rs[:group] %>"><%= row.contact_point&.group&.name %></td>
                <% end %>
                <td class="<%= text_cell %>"><%= row.contact_point&.name %></td>

                <%# Quân số (tổng) %>
                <td class="<%= num_cell %>"><%= row.calc_a ? row.calc_a.total_personnel : empty_mark %></td>
                <td class="<%= num_cell %>"><%= row.calc_b ? row.calc_b.total_personnel : empty_mark %></td>
                <td class="<%= num_cell %>"><%= row.diff ? row.diff[:total_personnel] : empty_mark %></td>

                <%# All metrics by section %>
                <% all_metrics.each do |_label, attr, type, color_hint| %>
                  <td class="<%= num_cell %>"><%= row.calc_a ? format_value.call(row.calc_a.send(attr), type) : empty_mark %></td>
                  <td class="<%= num_cell %>"><%= row.calc_b ? format_value.call(row.calc_b.send(attr), type) : empty_mark %></td>
                  <td class="<%= num_cell %> <%= row.diff ? delta_class.call(attr, row.diff[attr]) : '' %>"><%= row.diff ? format_value.call(row.diff[attr], type) : empty_mark %></td>
                <% end %>

                <%# Ghi chú %>
                <td class="<%= text_cell %> text-amber-700"><%= row.note %></td>
              </tr>
            <% end %>
          </tbody>

          <%# Hàng tổng %>
          <% if @comparison.any? %>
            <%
              sum_a = {}
              sum_b = {}
              sum_d = {}
              ([:total_personnel] + all_metrics.map { |m| m[1] }).each do |attr|
                sum_a[attr] = @comparison.sum { |r| r.calc_a&.send(attr) || 0 }
                sum_b[attr] = @comparison.sum { |r| r.calc_b&.send(attr) || 0 }
                sum_d[attr] = sum_b[attr] - sum_a[attr]
              end
            %>
            <tfoot>
              <tr class="bg-gray-100 font-semibold">
                <td colspan="<%= info_cols %>" class="<%= cell %> text-right">TỔNG</td>
                <td class="<%= num_cell %>"><%= sum_a[:total_personnel] %></td>
                <td class="<%= num_cell %>"><%= sum_b[:total_personnel] %></td>
                <td class="<%= num_cell %>"><%= sum_d[:total_personnel] %></td>
                <% all_metrics.each do |_label, attr, type, color_hint| %>
                  <td class="<%= num_cell %>"><%= format_value.call(sum_a[attr], type) %></td>
                  <td class="<%= num_cell %>"><%= format_value.call(sum_b[attr], type) %></td>
                  <td class="<%= num_cell %> <%= delta_class.call(attr, sum_d[attr]) %>"><%= format_value.call(sum_d[attr], type) %></td>
                <% end %>
                <td class="<%= cell %>"></td>
              </tr>
            </tfoot>
          <% end %>
        </table>
      </div>
    </div>
  <% end %>
<% end %>
