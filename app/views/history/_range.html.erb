<%
  period_options = @available_periods.map { |p| [period_label(p), p.id] }
  toolbar_filters = [
    { label: t("history.range.from_period"), param: :from_period_id,
      options: period_options, selected: @from_period&.id, blank_text: nil },
    { label: t("history.range.to_period"), param: :to_period_id,
      options: period_options, selected: @to_period&.id, blank_text: nil }
  ]
%>

<%= render "shared/list_toolbar",
     url: history_path(mode: "range"),
     total_count: @total_count,
     filters: toolbar_filters,
     extra_hidden: { mode: "range" },
     show_search: false,
     show_per_page: false,
     total_label: t("history.range.total_periods", count: @total_count) %>

<% if @period_summaries.blank? %>
  <div class="bg-gray-50 border border-gray-200 rounded p-4 text-gray-600">
    <%= t("history.range.no_periods_in_range") %>
  </div>
<% else %>
  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700"><%= t("history.range.columns.period") %></th>
          <th class="px-4 py-2 text-right text-xs font-semibold text-gray-700"><%= t("history.range.columns.deficit_kw") %></th>
          <th class="px-4 py-2 text-right text-xs font-semibold text-gray-700"><%= t("history.range.columns.deficit_amount") %></th>
          <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700"><%= t("history.range.columns.status") %></th>
        </tr>
      </thead>
      <tbody>
        <% @period_summaries.each do |period, summary| %>
          <tr class="border-t border-gray-100 hover:bg-yellow-50">
            <td class="px-4 py-2">
              <%= link_to period_label(period),
                    billing_path(period_id: period.id),
                    class: "text-blue-700 hover:underline" %>
            </td>
            <td class="px-4 py-2 text-right text-red-700">
              <% if summary.respond_to?(:deficit_kw) %>
                <%= number_to_vi(summary.deficit_kw) %>
              <% elsif summary.respond_to?(:units) %>
                <%= number_to_vi(summary.units.sum(BigDecimal("0")) { |d| BigDecimal(d[:deficit_kw].to_s) }) %>
              <% end %>
            </td>
            <td class="px-4 py-2 text-right">
              <% if summary.respond_to?(:deficit_amount) %>
                <%= money_to_vi(summary.deficit_amount) %>
              <% elsif summary.respond_to?(:units) %>
                <%= money_to_vi(summary.units.sum(BigDecimal("0")) { |d| BigDecimal(d[:deficit_amount].to_s) }) %>
              <% end %>
            </td>
            <td class="px-4 py-2 text-center">
              <% if period.open? %>
                <span class="inline-block px-2 py-0.5 rounded bg-green-100 text-green-700 text-xs"><%= t("common.badges.open") %></span>
              <% else %>
                <span class="inline-block px-2 py-0.5 rounded bg-gray-200 text-gray-700 text-xs"><%= t("common.badges.closed") %></span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
