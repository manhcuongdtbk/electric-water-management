<% available_roles = if current_user.technician?
                       %w[technician system_admin unit_admin commander]
                     else
                       %w[system_admin unit_admin commander]
                     end %>
<% available_units = Unit.kept.order(:name) %>

<%= form_with model: user, local: true, class: "space-y-4" do |f| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
      <ul class="list-disc list-inside">
        <% user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if user.new_record? %>
    <div>
      <%= f.label :username, "Tên đăng nhập", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :username, autocomplete: "username",
          class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
    </div>
  <% else %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Tên đăng nhập</label>
      <input type="text" disabled value="<%= user.username %>"
             class="block w-full rounded border border-gray-300 px-3 py-2 text-sm bg-gray-50">
    </div>
  <% end %>

  <div>
    <%= f.label :display_name, "Tên hiển thị", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :display_name,
        class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
  </div>

  <div>
    <%= f.label :role, "Vai trò", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :role,
        available_roles.map { |r| [t("activerecord.attributes.user.roles.#{r}", default: r), r] },
        { include_blank: "— Chọn vai trò —" },
        class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
  </div>

  <div>
    <%= f.label :unit_id, "Đơn vị (bắt buộc cho quản trị viên đơn vị / chỉ huy)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :unit_id,
        available_units.pluck(:name, :id),
        { include_blank: "— Không thuộc đơn vị nào —" },
        class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
  </div>

  <div class="border-t border-gray-200 pt-4">
    <h3 class="text-sm font-semibold text-gray-700 mb-2">
      <%= user.new_record? ? "Mật khẩu" : "Đổi mật khẩu (để trống nếu không đổi)" %>
    </h3>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :password, "Mật khẩu", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :password_confirmation, "Xác nhận", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
      </div>
    </div>
    <p class="text-xs text-gray-500 mt-1">Tối thiểu 8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt.</p>
  </div>

  <div class="flex space-x-2">
    <%= f.submit "Lưu", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Hủy", users_path, class: "text-gray-600 px-4 py-2 hover:text-gray-800" %>
  </div>
<% end %>
