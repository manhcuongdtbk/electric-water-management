<% content_for :title, t("users.index.title") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-semibold text-gray-900"><%= t("users.index.title") %></h1>
  <%= link_to t("users.index.new_button"), new_user_path,
        class: "inline-flex items-center gap-1.5 rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left font-medium text-gray-600 w-10"><%= t("users.index.columns.stt") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("users.index.columns.full_name") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("users.index.columns.email") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("users.index.columns.role") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("users.index.columns.organization") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("users.index.columns.status") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("users.index.columns.last_sign_in") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("users.index.columns.actions") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @users.any? %>
        <% @users.each_with_index do |user, idx| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-500"><%= idx + 1 %></td>
            <td class="px-4 py-3 font-medium text-gray-900"><%= user.full_name %></td>
            <td class="px-4 py-3 text-gray-700"><%= user.email %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                <%= user.admin_level1? ? 'bg-purple-100 text-purple-800' :
                    user.admin_unit?   ? 'bg-blue-100 text-blue-800' :
                    user.commander?    ? 'bg-green-100 text-green-800' :
                                         'bg-gray-100 text-gray-700' %>">
                <%= t("users.roles.#{user.role}") %>
              </span>
            </td>
            <td class="px-4 py-3 text-gray-700"><%= user.organization&.name || "—" %></td>
            <td class="px-4 py-3">
              <% if user.access_locked? %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-red-100 text-red-700">
                  <%= t("users.index.status.locked") %>
                </span>
              <% else %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-green-100 text-green-700">
                  <%= t("users.index.status.active") %>
                </span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs">
              <%= user.last_sign_in_at ? l(user.last_sign_in_at, format: :default) : "—" %>
            </td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <%= link_to t("users.actions.edit"), edit_user_path(user),
                      class: "text-blue-600 hover:underline text-xs" %>
                <% if user != current_user %>
                  <% if user.access_locked? %>
                    <%= button_to t("users.actions.unlock"), unlock_user_path(user), method: :patch,
                          data: { turbo_confirm: t("users.actions.unlock_confirm") },
                          class: "text-green-600 hover:underline text-xs bg-transparent border-0 cursor-pointer p-0" %>
                  <% else %>
                    <%= button_to t("users.actions.lock"), lock_user_path(user), method: :patch,
                          data: { turbo_confirm: t("users.actions.lock_confirm") },
                          class: "text-red-600 hover:underline text-xs bg-transparent border-0 cursor-pointer p-0" %>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="8" class="px-4 py-8 text-center text-gray-400"><%= t("users.index.empty") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
