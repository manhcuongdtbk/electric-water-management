<% page_title t("sidebar.items.users") %>

<%
  add_link = can?(:create, User) ?
    link_to(t("common.actions.add") + " " + t("resources.user"), new_user_path,
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700") : nil
%>

<%
  role_options = UsersController::ROLES.map { |r| [I18n.t("activerecord.attributes.user.roles.#{r}"), r] }
%>

<%= render "shared/list_toolbar",
      url: users_path,
      search_placeholder: "Tìm theo tên đăng nhập hoặc tên hiển thị...",
      total_count: @total_count,
      add_link: add_link,
      per_page_storage_key: "users_per_page",
      filters: [
        { label: "Vai trò:", param: :role,
          options: role_options, selected: @filter_role },
        { label: "Khu vực:", param: :zone_id,
          options: @available_zones.pluck(:name, :id), selected: @zone&.id,
          children: [:unit_id] },
        { label: "Đơn vị:", param: :unit_id,
          options: @available_units.pluck(:name, :id), selected: @unit&.id }
      ] %>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <%= sortable_header :username, t("activerecord.attributes.user.username"),
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], role: params[:role], zone_id: params[:zone_id], unit_id: params[:unit_id] } %>
        <%= sortable_header :display_name, t("activerecord.attributes.user.display_name"),
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], role: params[:role], zone_id: params[:zone_id], unit_id: params[:unit_id] } %>
        <%= sortable_header :zone, "Khu vực",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], role: params[:role], zone_id: params[:zone_id], unit_id: params[:unit_id] } %>
        <%= sortable_header :unit, t("activerecord.attributes.user.unit"),
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], role: params[:role], zone_id: params[:zone_id], unit_id: params[:unit_id] } %>
        <%= sortable_header :role, t("activerecord.attributes.user.role"),
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], role: params[:role], zone_id: params[:zone_id], unit_id: params[:unit_id] } %>
        <%= list_header t("common.list.actions"), align: :right %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @users.empty? %>
        <tr><td colspan="6" class="px-4 py-6 text-center text-gray-500"><%= t("common.list.no_records") %></td></tr>
      <% end %>
      <% @users.each do |u| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-2 text-sm font-medium text-gray-900">
            <%= u.username %>
            <% if u.default_account? %>
              <span class="ml-1 text-xs bg-gray-100 text-gray-600 px-1 rounded"><%= t("common.badges.default_account") %></span>
            <% end %>
          </td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= u.display_name %></td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= u.unit&.zone&.name || "—" %></td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= u.unit&.name || "—" %></td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <%= t("activerecord.attributes.user.roles.#{u.role}", default: u.role) %>
          </td>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if can?(:update, u) || can?(:destroy, u) %>
              <% if can?(:update, u) %>
                <%= link_to t("common.actions.edit"), edit_user_path(u),
                      class: "text-blue-600 hover:text-blue-800" %>
              <% end %>
              <% if can?(:destroy, u) %>
                <%= button_to t("common.actions.destroy"), user_path(u), method: :delete,
                      form: { class: "inline", data: { turbo_confirm: t("common.confirm.destroy_named", name: u.username) } },
                      class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
              <% end %>
            <% else %>
              <%= empty_actions_dash %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
