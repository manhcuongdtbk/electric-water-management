<% content_for :title, t("users.index.title") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-semibold text-gray-900"><%= t("users.index.title") %></h1>
  <%= link_to t("users.index.new_button"), new_user_path,
        class: "inline-flex items-center gap-1.5 rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors" %>
</div>

<%# Search form %>
<%= search_form_for @q, url: users_path, html: { class: "mb-4 flex flex-wrap gap-2" } do |f| %>
  <%= f.text_field :full_name_or_email_cont,
        placeholder: t("users.index.search_placeholder"),
        class: "border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-64" %>
  <%= f.select :role_eq,
        User.roles.map { |r, v| [ t("users.roles.#{r}"), v ] },
        { include_blank: t("users.index.all_roles") },
        class: "border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  <%= f.select :organization_id_eq,
        options_from_collection_for_select(@organizations, :id, :name, params.dig(:q, :organization_id_eq)),
        { include_blank: t("users.index.all_organizations") },
        class: "border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  <%= select_tag :status,
        options_for_select([
          [ t("users.index.status.active"), "active" ],
          [ t("users.index.status.locked"), "locked" ]
        ], params[:status]),
        include_blank: t("users.index.all_statuses"),
        class: "border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  <%= f.submit t("common.search.submit"),
        class: "px-4 py-1.5 bg-gray-600 text-white text-sm rounded-md hover:bg-gray-700 cursor-pointer transition-colors" %>
  <%= link_to t("common.search.clear"), users_path(sort: params[:sort].presence, direction: params[:direction].presence),
        class: "px-4 py-1.5 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50 transition-colors" %>
<% end %>

<% current_sort  = params[:sort].presence || "organization"
   current_dir   = params[:direction].presence || "asc"
   q_params      = params[:q]&.to_unsafe_h.presence
   status_param  = params[:status].presence

   sort_link = ->(col, label) do
     next_dir = (current_sort == col && current_dir == "asc") ? "desc" : "asc"
     icon = current_sort == col ? (current_dir == "asc" ? " ↑" : " ↓") : nil
     link_to users_path(q: q_params, sort: col, direction: next_dir, status: status_param),
             class: "inline-flex items-center gap-0.5 hover:text-blue-600 transition-colors" do
       safe_join([ label, icon ? content_tag(:span, icon, class: "text-gray-500 text-xs") : nil ].compact)
     end
   end

   render_user_cells = ->(user) do
     capture do
       concat content_tag(:td, class: "px-4 py-3 text-gray-700 align-middle") {
         link_to user.full_name, edit_user_path(user), class: "hover:text-blue-600 transition-colors"
       }
       concat content_tag(:td, class: "px-4 py-3 text-gray-700 align-middle") {
         link_to user.email, edit_user_path(user), class: "hover:text-blue-600 transition-colors"
       }
       concat content_tag(:td, t("users.roles.#{user.role}"), class: "px-4 py-3 text-gray-700 align-middle")
       concat content_tag(:td, t("users.index.status.#{user.access_locked? ? 'locked' : 'active'}"), class: "px-4 py-3 text-gray-700 align-middle")
       concat content_tag(:td, (user.last_sign_in_at ? l(user.last_sign_in_at, format: :default) : "—"), class: "px-4 py-3 text-gray-700 align-middle")
       concat content_tag(:td, class: "px-4 py-3 align-middle") {
         if user != current_user
           if user.access_locked?
             button_to t("users.actions.unlock"), unlock_user_path(user), method: :patch,
                       data: { turbo_confirm: t("users.actions.unlock_confirm") },
                       class: "text-green-600 hover:underline text-xs bg-transparent border-0 cursor-pointer p-0"
           else
             button_to t("users.actions.lock"), lock_user_path(user), method: :patch,
                       data: { turbo_confirm: t("users.actions.lock_confirm") },
                       class: "text-red-600 hover:underline text-xs bg-transparent border-0 cursor-pointer p-0"
           end
         end
       }
     end
   end %>

<%# Table %>
<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-gray-600 w-40">
          <%= sort_link.call("organization", t("users.index.columns.organization")) %>
        </th>
        <th class="px-4 py-3 text-left text-gray-600">
          <%= sort_link.call("full_name", t("users.index.columns.full_name")) %>
        </th>
        <th class="px-4 py-3 text-left text-gray-600"><%= t("users.index.columns.email") %></th>
        <th class="px-4 py-3 text-left text-gray-600">
          <%= sort_link.call("role", t("users.index.columns.role")) %>
        </th>
        <th class="px-4 py-3 text-left text-gray-600"><%= t("users.index.columns.status") %></th>
        <th class="px-4 py-3 text-left text-gray-600"><%= t("users.index.columns.last_sign_in") %></th>
        <th class="px-4 py-3 text-left text-gray-600"><%= t("users.index.columns.actions") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @division_users.empty? && @users_by_org.empty? %>
        <tr>
          <td colspan="7" class="px-4 py-8 text-center text-gray-400">
            <%= (q_params.present? || status_param.present?) ? t("users.index.empty_filtered") : t("users.index.empty") %>
          </td>
        </tr>
      <% else %>

        <%# Division section %>
        <% if @division_users.any? %>
          <tr class="bg-gray-50">
            <td colspan="7" class="px-4 py-2 text-xs font-medium text-gray-500">
              <%= t("users.index.division_section") %>
            </td>
          </tr>
          <% @division_users.each do |user| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-400 align-middle border-r border-gray-200">—</td>
              <%= render_user_cells.call(user) %>
            </tr>
          <% end %>
        <% end %>

        <%# Unit section %>
        <% if @users_by_org.any? %>
          <tr class="bg-gray-50">
            <td colspan="7" class="px-4 py-2 text-xs font-medium text-gray-500">
              <%= t("users.index.unit_section") %>
            </td>
          </tr>
          <% @users_by_org.each do |organization, users| %>
            <% users.each_with_index do |user, i| %>
              <tr class="hover:bg-gray-50">
                <% if i == 0 %>
                  <td class="px-4 py-3 text-gray-700 align-middle border-r border-gray-200"
                      rowspan="<%= users.size %>">
                    <% if can?(:update, organization) %>
                      <%= link_to organization.name, edit_organization_path(organization), class: "hover:text-blue-600 transition-colors" %>
                    <% else %>
                      <%= organization.name %>
                    <% end %>
                  </td>
                <% end %>
                <%= render_user_cells.call(user) %>
              </tr>
            <% end %>
          <% end %>
        <% end %>

      <% end %>
    </tbody>
  </table>
</div>

<%# Pagination %>
<%= render "shared/pagination", pagy: @pagy %>
