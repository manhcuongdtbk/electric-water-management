<% content_for :title, t("organizations.index.title") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-semibold text-gray-900"><%= t("organizations.index.title") %></h1>
  <%= link_to t("organizations.index.new_button"), new_organization_path,
        class: "inline-flex items-center gap-1.5 rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left font-medium text-gray-600 w-10"><%= t("organizations.index.columns.stt") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("organizations.index.columns.name") %></th>
        <th class="px-4 py-3 text-right font-medium text-gray-600"><%= t("organizations.index.columns.contact_points_count") %></th>
        <th class="px-4 py-3 text-right font-medium text-gray-600"><%= t("organizations.index.columns.users_count") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("organizations.index.columns.actions") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @organizations.any? %>
        <% @organizations.each_with_index do |organization, idx| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-500"><%= idx + 1 %></td>
            <td class="px-4 py-3 font-medium text-gray-900"><%= organization.name %></td>
            <td class="px-4 py-3 text-right text-gray-700"><%= organization.contact_points.size %></td>
            <td class="px-4 py-3 text-right text-gray-700"><%= organization.users.size %></td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <%= link_to t("organizations.actions.edit"), edit_organization_path(organization),
                      class: "text-blue-600 hover:underline text-xs" %>
                <%= button_to t("organizations.actions.delete"), organization_path(organization),
                      method: :delete,
                      data: { turbo_confirm: t("organizations.actions.delete_confirm") },
                      class: "text-red-600 hover:underline text-xs bg-transparent border-0 cursor-pointer p-0" %>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="5" class="px-4 py-8 text-center text-gray-400"><%= t("organizations.index.empty") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
