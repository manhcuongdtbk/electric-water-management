<div class="max-w-md mx-auto bg-white rounded-lg shadow border border-gray-200 p-6 mt-12"
     data-controller="password-validator">
  <h1 class="text-2xl font-semibold mb-4 text-gray-900">
    <%= @force_change ? t("password_changes.edit.title_force") : t("password_changes.edit.title_voluntary") %>
  </h1>

  <% if @force_change %>
    <p class="text-sm text-gray-600 mb-6"><%= t("password_changes.edit.force_note") %></p>
  <% end %>

  <%= form_with model: current_user, url: password_change_path, method: :patch, local: true do |f| %>
    <% if current_user.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded p-3 mb-4 text-sm text-red-700">
        <ul class="list-disc list-inside space-y-1">
          <% current_user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% unless @force_change %>
      <div class="mb-4">
        <%= f.label :current_password, t("password_changes.edit.current_password_label"),
              class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :current_password, autocomplete: "current-password",
              class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :password, t("password_changes.edit.new_password_label"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "new-password",
            data: { password_validator_target: "password",
                    action: "input->password-validator#validate blur->password-validator#validate" },
            class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div class="mb-4">
      <%= f.label :password_confirmation, t("password_changes.edit.confirm_label"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            data: { password_validator_target: "confirmation",
                    action: "input->password-validator#validate blur->password-validator#validate" },
            class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <ul class="mb-6 space-y-1 text-sm text-gray-500">
      <% %w[length upper lower digit special match].each do |key| %>
        <li data-password-validator-target="rule" data-rule-key="<%= key %>"
            class="flex items-center gap-2">
          <span data-rule-icon class="inline-block w-4 text-center">○</span>
          <span><%= t("password_validator.rules.#{key}") %></span>
        </li>
      <% end %>
    </ul>

    <%= f.submit t("password_changes.edit.submit"),
          data: { password_validator_target: "submit" },
          class: "w-full bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 cursor-pointer" %>
  <% end %>
</div>
