<div class="max-w-md mx-auto bg-white rounded-lg shadow border border-gray-200 p-6 mt-12">
  <h1 class="text-2xl font-semibold mb-4 text-gray-900">Đổi mật khẩu</h1>
  <p class="text-sm text-gray-600 mb-6">
    Đây là lần đăng nhập đầu tiên. Vui lòng đổi mật khẩu trước khi tiếp tục sử dụng hệ thống.
  </p>

  <%= form_with model: current_user, url: password_change_path, method: :patch, local: true do |f| %>
    <% if current_user.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded p-3 mb-4 text-sm text-red-700">
        <ul class="list-disc list-inside space-y-1">
          <% current_user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :password, "Mật khẩu mới", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, required: true, autocomplete: "new-password",
          class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
      <p class="text-xs text-gray-500 mt-1">Tối thiểu 8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt.</p>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, "Xác nhận mật khẩu", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
          class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <%= f.submit "Đổi mật khẩu", class: "w-full bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 cursor-pointer" %>
  <% end %>
</div>
