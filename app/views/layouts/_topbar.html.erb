<header class="bg-gray-800 h-12 flex items-center px-6 justify-between flex-shrink-0 text-sm">
  <div class="flex items-center space-x-6">
    <span class="font-semibold text-white"><%= t("application.name") %></span>
    <% if current_period %>
      <span class="text-gray-300"><%= period_label(current_period) %> — <%= t("common.badges.open") %></span>
    <% else %>
      <span class="text-yellow-400"><%= t("dashboard.no_period.title", default: "Không có kỳ đang mở") %></span>
    <% end %>
  </div>
  <div class="flex items-center space-x-4 text-gray-300">
    <span class="text-white"><%= current_user.display_name %></span>
    <span><%= t("activerecord.attributes.user.roles.#{current_user.role}", default: current_user.role) %></span>
    <%= link_to t("common.actions.change_password"), edit_password_change_path,
          class: "hover:text-white" %>
    <%= button_to t("common.actions.logout"), destroy_user_session_path, method: :delete,
        class: "text-red-400 hover:text-red-300 cursor-pointer bg-transparent border-0 p-0",
        form: { data: { turbo: false } } %>
  </div>
</header>
