<!DOCTYPE html>
<html lang="vi">
  <head>
    <title><%= content_for(:title) || t("app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 antialiased">
    <% expires_at = session_expires_at %>
    <% if user_signed_in? && expires_at %>
      <div data-controller="session-timeout"
           data-session-timeout-expires-at-value="<%= expires_at.to_i %>"
           data-session-timeout-timeout-in-value="<%= Devise.timeout_in.to_i %>">
        <%= render "layouts/session_timeout_warning" %>
      </div>
    <% end %>
    <% if user_signed_in? && !current_user.force_password_change? %>
      <div class="flex h-screen overflow-hidden">
        <%# Sidebar %>
        <aside class="w-60 bg-slate-800 text-white flex flex-col flex-shrink-0">
          <div class="px-4 py-5 border-b border-slate-700">
            <h1 class="text-sm font-bold leading-snug text-white">Quản lý Điện Nước</h1>
            <p class="text-xs text-slate-400 mt-0.5 truncate"><%= current_user.organization.name %></p>
          </div>

          <nav class="flex-1 px-2 py-4 space-y-0.5 overflow-y-auto">
            <% unless current_user.tech? %>
              <%= link_to dashboard_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded text-sm font-medium transition-colors #{controller_name == 'dashboard' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'}" do %>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                <%= t("nav.dashboard") %>
              <% end %>
            <% end %>
            <% if can? :read, ContactPoint %>
              <%= link_to contact_points_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded text-sm font-medium transition-colors #{controller_name == 'contact_points' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'}" do %>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <%= t("nav.contact_points") %>
              <% end %>
            <% end %>
            <% if can? :read, UnitConfig %>
              <%= link_to unit_config_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded text-sm font-medium transition-colors #{controller_name == 'unit_configs' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'}" do %>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <%= t("nav.unit_config") %>
              <% end %>
            <% end %>
            <% if can? :read, UnitConfig %>
              <%= link_to electricity_supply_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded text-sm font-medium transition-colors #{controller_name == 'electricity_supplies' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'}" do %>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                <%= t("nav.electricity_supply") %>
              <% end %>
            <% end %>
            <% if can? :read, MeterReading %>
              <%= link_to meter_readings_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded text-sm font-medium transition-colors #{controller_name == 'meter_readings' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'}" do %>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
                <%= t("nav.meter_readings") %>
              <% end %>
            <% end %>
            <% if can? :read, Personnel %>
              <%= link_to personnel_review_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded text-sm font-medium transition-colors #{controller_name == 'personnel_reviews' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'}" do %>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
                <%= t("nav.personnel_review") %>
              <% end %>
            <% end %>
            <% if can? :read, MonthlyCalculation %>
              <%= link_to monthly_summary_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded text-sm font-medium transition-colors #{controller_name == 'monthly_summaries' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'}" do %>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18M10 3v18M6 3h12a3 3 0 013 3v12a3 3 0 01-3 3H6a3 3 0 01-3-3V6a3 3 0 013-3z" />
                </svg>
                <%= t("nav.monthly_summary") %>
              <% end %>
            <% end %>
            <% if can? :manage, User %>
              <%= link_to users_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded text-sm font-medium transition-colors #{controller_name == 'users' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'}" do %>
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                <%= t("nav.users") %>
              <% end %>
            <% end %>
          </nav>

          <div class="px-3 py-4 border-t border-slate-700">
            <div class="text-xs text-slate-400 truncate mb-2"><%= current_user.full_name %></div>
            <%= button_to t("nav.sign_out"), destroy_user_session_path, method: :delete,
                  class: "w-full text-left text-xs text-slate-400 hover:text-white transition-colors px-0 bg-transparent border-0 cursor-pointer" %>
          </div>
        </aside>

        <%# Main content %>
        <main class="flex-1 overflow-auto">
          <div class="p-6 max-w-7xl mx-auto">
            <% if notice %>
              <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">
                <%= notice %>
              </div>
            <% end %>
            <% if alert %>
              <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
                <%= alert %>
              </div>
            <% end %>
            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <div class="min-h-screen flex items-center justify-center">
        <% if notice %>
          <div class="fixed top-4 left-1/2 -translate-x-1/2 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">
            <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="fixed top-4 left-1/2 -translate-x-1/2 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
            <%= alert %>
          </div>
        <% end %>
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
