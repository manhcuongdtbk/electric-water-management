<% page_title t("sidebar.items.units") %>

<%
  add_link = can?(:create, Unit) ?
    link_to(t("common.actions.add") + " " + t("resources.unit"), new_unit_path,
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700") : nil
%>

<%= render "shared/list_toolbar",
      url: units_path,
      search_placeholder: t("common.list.search_by_name"),
      total_count: @total_count,
      add_link: add_link %>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <%= sortable_header :name, t("activerecord.attributes.unit.name"),
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page] } %>
        <%= sortable_header :zone, t("activerecord.attributes.unit.zone"),
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page] } %>
        <%= sortable_header :is_manager, "Là đơn vị quản lý khu vực",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page] } %>
        <%= list_header t("common.list.actions"), align: :right %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @units.empty? %>
        <tr><td colspan="4" class="px-4 py-6 text-center text-gray-500"><%= t("common.list.no_records") %></td></tr>
      <% end %>
      <% @units.each do |u| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-2 text-sm font-medium text-gray-900"><%= u.name %></td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= u.zone.name %></td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <% if u.managed_zones.any? %>
              <span class="text-blue-700">Có (<%= u.managed_zones.map(&:name).join(", ") %>)</span>
            <% else %>—
            <% end %>
          </td>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if can?(:update, u) || can?(:destroy, u) %>
              <% if can?(:update, u) %>
                <%= link_to t("common.actions.edit"), edit_unit_path(u),
                      class: "text-blue-600 hover:text-blue-800" %>
              <% end %>
              <% if can?(:destroy, u) %>
                <%
                  confirm_msg = t("common.confirm.destroy_named", name: u.name)
                  confirm_msg += " Đơn vị này đang quản lý khu vực — khu vực sẽ không còn đơn vị quản lý." if u.managed_zones.any?
                %>
                <%= button_to t("common.actions.destroy"), unit_path(u), method: :delete,
                      form: { class: "inline", data: { turbo_confirm: confirm_msg } },
                      class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
              <% end %>
            <% else %>
              <%= empty_actions_dash %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
