<%= form_with model: unit, local: true, class: "space-y-4" do |f| %>
  <% if unit.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
      <ul class="list-disc list-inside">
        <% unit.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Tên đơn vị", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
        class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
  </div>

  <div>
    <%= f.label :zone_id, "Khu vực", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% if unit.persisted? %>
      <input type="text" disabled value="<%= unit.zone.name %>"
             class="block w-full rounded border border-gray-300 px-3 py-2 text-sm bg-gray-50">
      <p class="text-xs text-gray-500 mt-1">Khu vực không thể thay đổi sau khi tạo đơn vị.</p>
    <% else %>
      <%= f.select :zone_id, Zone.accessible_by(current_ability).order(:name).pluck(:name, :id),
          { include_blank: "— Chọn khu vực —" },
          class: "block w-full rounded border border-gray-300 px-3 py-2 text-sm" %>
    <% end %>
  </div>

  <div class="flex space-x-2">
    <%= f.submit "Lưu", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Hủy", units_path, class: "text-gray-600 px-4 py-2 hover:text-gray-800" %>
  </div>
<% end %>
