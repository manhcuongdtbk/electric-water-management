<% container_class = local_assigns.fetch(:container_class, "mb-4") %>
<% if notice %>
  <div class="<%= container_class %> rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">
    <%= notice %>
  </div>
<% end %>
<% if alert %>
  <div class="<%= container_class %> rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
    <%= alert %>
  </div>
<% end %>
