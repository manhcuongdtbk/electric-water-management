<% page_title t("sidebar.items.pump_allocations") %>

<%= render "shared/period_indicator", period: @period %>

<%
  add_link = (@period && can?(:create, PumpAllocation)) ?
    link_to(t("common.actions.add") + " " + t("resources.pump_allocation"), new_pump_allocation_path,
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700") : nil
%>

<div class="bg-white border border-gray-200 rounded-lg p-3 mb-3 flex items-center justify-between gap-3 flex-wrap">
  <div class="flex items-center gap-3 flex-wrap">
    <%= form_with url: pump_allocations_path, method: :get, local: true, class: "flex items-center gap-2" do %>
      <%= hidden_field_tag :per_page, params[:per_page] if params[:per_page].present? %>
      <%= hidden_field_tag :zone_id, @selected_zone_id if @selected_zone_id.present? %>
      <%= text_field_tag :q, params[:q],
            placeholder: t("common.list.search_by_name"),
            class: "rounded border border-gray-300 text-sm px-3 py-1.5 w-64" %>
      <%= submit_tag t("common.actions.search"),
            class: "px-3 py-1.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded cursor-pointer" %>
      <% if params[:q].present? || @selected_zone_id.present? %>
        <%= link_to t("common.list.clear_filter"), pump_allocations_path,
              class: "text-sm text-gray-600 hover:text-gray-800 underline" %>
      <% end %>
    <% end %>

    <%= form_with url: pump_allocations_path, method: :get, local: true, class: "flex items-center gap-2" do %>
      <%= hidden_field_tag :q, params[:q] if params[:q].present? %>
      <%= hidden_field_tag :per_page, params[:per_page] if params[:per_page].present? %>
      <label class="text-xs text-gray-600 whitespace-nowrap">Khu vực:</label>
      <%= select_tag :zone_id,
            options_for_select(
              [["Tất cả", ""]] + @zones.pluck(:name, :id),
              @selected_zone_id
            ),
            onchange: "this.form.requestSubmit()",
            class: "rounded border border-gray-300 text-sm px-2 py-1" %>
    <% end %>

    <%= form_with url: pump_allocations_path, method: :get, local: true, class: "flex items-center gap-2" do %>
      <%= hidden_field_tag :q, params[:q] if params[:q].present? %>
      <%= hidden_field_tag :zone_id, @selected_zone_id if @selected_zone_id.present? %>
      <label class="text-xs text-gray-600 whitespace-nowrap"><%= t("common.list.per_page") %></label>
      <%= select_tag :per_page,
            options_for_select([10, 25, 50, 100].map { |n| [n, n] }, (params[:per_page].presence || 25).to_i),
            data: { controller: "per-page", action: "change->per-page#submit",
                    per_page_storage_key_value: "pump_allocations_per_page" },
            class: "rounded border border-gray-300 text-sm px-2 py-1" %>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <span class="text-sm text-gray-600"><%= list_total(@total_count) %></span>
    <% if add_link %>
      <%= add_link %>
    <% end %>
  </div>
</div>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <%= sortable_header :zone, t("activerecord.attributes.zone.name"),
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], zone_id: params[:zone_id] } %>
        <%= sortable_header :target, "Đối tượng",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], zone_id: params[:zone_id] } %>
        <%= sortable_header :percentage, "% cố định",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], zone_id: params[:zone_id] }, align: :right %>
        <%= sortable_header :coefficient, "Hệ số",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], zone_id: params[:zone_id] }, align: :right %>
        <%= list_header t("common.list.actions"), align: :right %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @pump_allocations.empty? %>
        <tr><td colspan="5" class="px-4 py-6 text-center text-gray-500"><%= t("common.list.no_records") %></td></tr>
      <% end %>
      <% @pump_allocations.each do |alloc| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-2 text-sm text-gray-900"><%= alloc.zone.name %></td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <%= alloc.unit&.name || alloc.contact_point&.name %>
            <span class="text-xs text-gray-400 ml-1">
              (<%= alloc.unit ? t("resources.unit").capitalize : t("resources.contact_point").capitalize %>)
            </span>
          </td>
          <td class="px-4 py-2 text-sm text-right text-gray-600">
            <%= alloc.fixed_percentage.present? ? "#{number_to_vi(alloc.fixed_percentage)}%" : "—" %>
          </td>
          <td class="px-4 py-2 text-sm text-right text-gray-600">
            <%= alloc.fixed_percentage.present? ? "—" : number_to_vi(alloc.coefficient) %>
          </td>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if can?(:update, alloc) || can?(:destroy, alloc) %>
              <% if can?(:update, alloc) %>
                <%= link_to t("common.actions.edit"), edit_pump_allocation_path(alloc),
                      class: "text-blue-600 hover:text-blue-800" %>
              <% end %>
              <% if can?(:destroy, alloc) %>
                <%= button_to t("common.actions.destroy"), pump_allocation_path(alloc), method: :delete,
                      form: { class: "inline", data: { turbo_confirm: t("common.confirm.destroy") } },
                      class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
              <% end %>
            <% else %>
              <%= empty_actions_dash %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
