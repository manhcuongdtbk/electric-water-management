<% page_title t("sidebar.items.pump_allocations") %>

<%= render "shared/period_indicator", period: @period %>

<%
  add_link = (@period && can?(:create, PumpAllocation)) ?
    link_to(t("common.actions.add") + " " + t("resources.pump_allocation"), new_pump_allocation_path,
      class: "bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700") : nil
%>

<%
  toolbar_filters = []
  if current_user.role == "system_admin"
    toolbar_filters = [
      { label: "Khu vực:", param: :zone_id,
        options: @zones.pluck(:name, :id), selected: @selected_zone_id }
    ]
  end
%>

<%= render "shared/list_toolbar",
      url: pump_allocations_path,
      search_placeholder: "Tìm theo tên đối tượng...",
      total_count: @total_count,
      add_link: add_link,
      per_page_storage_key: "pump_allocations_per_page",
      filters: toolbar_filters %>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <%= sortable_header :target, "Đối tượng",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], zone_id: params[:zone_id] } %>
        <%= sortable_header :zone, "Khu vực",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], zone_id: params[:zone_id] } %>
        <%= sortable_header :target_type, "Loại",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], zone_id: params[:zone_id] } %>
        <%= sortable_header :percentage, "% cố định",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], zone_id: params[:zone_id] }, align: :right %>
        <%= sortable_header :coefficient, "Hệ số",
              current_sort: params[:sort], current_dir: params[:dir],
              extra_params: { q: params[:q], per_page: params[:per_page], zone_id: params[:zone_id] }, align: :right %>
        <%= list_header t("common.list.actions"), align: :right %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @pump_allocations.empty? %>
        <tr><td colspan="6" class="px-4 py-6 text-center text-gray-500"><%= t("common.list.no_records") %></td></tr>
      <% end %>
      <% @pump_allocations.each do |alloc| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-2 text-sm font-medium text-gray-900">
            <%= alloc.unit&.name || alloc.contact_point&.name %>
          </td>
          <td class="px-4 py-2 text-sm text-gray-600"><%= alloc.zone.name %></td>
          <td class="px-4 py-2 text-sm text-gray-600">
            <%= alloc.unit ? t("resources.unit").capitalize : t("resources.contact_point").capitalize %>
          </td>
          <td class="px-4 py-2 text-sm text-right text-gray-600">
            <%= alloc.fixed_percentage.present? ? "#{number_to_vi(alloc.fixed_percentage)}%" : "—" %>
          </td>
          <td class="px-4 py-2 text-sm text-right text-gray-600">
            <%= alloc.fixed_percentage.present? ? "—" : number_to_vi(alloc.coefficient) %>
          </td>
          <td class="px-4 py-2 text-sm text-right space-x-2">
            <% if can?(:update, alloc) || can?(:destroy, alloc) %>
              <% if can?(:update, alloc) %>
                <%= link_to t("common.actions.edit"), edit_pump_allocation_path(alloc),
                      class: "text-blue-600 hover:text-blue-800" %>
              <% end %>
              <% if can?(:destroy, alloc) %>
                <%= button_to t("common.actions.destroy"), pump_allocation_path(alloc), method: :delete,
                      form: { class: "inline", data: { turbo_confirm: t("common.confirm.destroy") } },
                      class: "text-red-600 hover:text-red-800 underline inline cursor-pointer bg-transparent border-0 p-0" %>
              <% end %>
            <% else %>
              <%= empty_actions_dash %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
