<table class="min-w-full divide-y divide-gray-200">
  <thead class="bg-gray-50">
    <tr>
      <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("unit_config.other_deductions.headers.contact_point") %></th>
      <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("unit_config.other_deductions.headers.type") %></th>
      <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("unit_config.other_deductions.headers.value") %></th>
    </tr>
  </thead>
  <tbody class="divide-y divide-gray-200">
    <% other_deductions.each do |od| %>
      <% cp_personnel = @personnel_by_contact_point_id[od.contact_point_id] || 0 %>
      <% unit_total = od.contact_point.unit_id ? (@unit_total_personnel[od.contact_point.unit_id] || 0) : 0 %>
      <tr data-controller="other-deduction"
          data-other-deduction-contact-point-personnel-value="<%= cp_personnel %>"
          data-other-deduction-unit-total-personnel-value="<%= unit_total %>">
        <td class="px-4 py-2 text-sm text-gray-900"><%= od.contact_point.name %></td>
        <td class="px-4 py-2 text-sm">
          <%= hidden_field_tag "other_deductions[#{od.id}][lock_version]", od.lock_version %>
          <% type_keys = %w[fixed coefficient]
             type_keys << "unit_coefficient" if od.contact_point.unit_id.present?
             type_options = type_keys.map { |key| [t("unit_config.other_deductions.types.#{key}"), key] } %>
          <%= select_tag "other_deductions[#{od.id}][other_type]",
              options_for_select(type_options, od.other_type),
              disabled: !can_edit,
              data: { other_deduction_target: "typeSelect", action: "other-deduction#typeChanged" },
              class: "rounded border border-gray-300 px-2 py-1 text-sm" %>
        </td>
        <td class="px-4 py-2 text-sm">
          <%= number_field_tag "other_deductions[#{od.id}][other_value]", od.other_value,
              step: "0.01", disabled: !can_edit,
              placeholder: od.other_fixed? ? t("unit_config.other_deductions.placeholder.fixed") : t("unit_config.other_deductions.placeholder.coefficient"),
              data: { other_deduction_target: "valueInput", action: "input->other-deduction#valueChanged" },
              class: "w-32 rounded border border-gray-300 px-2 py-1 text-sm text-right" %>
          <div data-other-deduction-target="preview"
               class="hidden mt-1 text-xs text-gray-500"></div>
          <div data-other-deduction-target="estimateLabel"
               class="hidden mt-0.5 text-xs text-gray-400"><%= t("unit_config.other_deductions.preview.estimate_label") %></div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<p class="px-4 py-2 text-xs text-gray-500"><%= t("unit_config.other_deductions.type_explanation") %></p>
