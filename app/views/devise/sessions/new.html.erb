<h2>Đăng nhập</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="field">
    <p><%= f.label :username, "Tên đăng nhập" %></p>
    <p><%= f.text_field :username, autofocus: true, autocomplete: "username" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password, "Mật khẩu" %></p>
    <p><%= f.password_field :password, autocomplete: "current-password" %></p>
  </div>

  <div class="actions">
    <%= f.submit "Đăng nhập" %>
  </div>
<% end %>
