<% content_for :title, "Đăng nhập" %>

<div class="bg-white rounded-lg shadow p-8 w-full max-w-md">
  <div class="mb-6 text-center">
    <h1 class="text-base font-bold text-gray-900">Quản lý Điện Nước</h1>
    <p class="text-xs text-gray-500 mt-0.5">Hệ thống quản lý nội bộ</p>
  </div>

  <h2 class="text-xl font-bold text-gray-900 mb-6">Đăng nhập</h2>

  <%= form_with url: user_session_path, scope: :user do |f| %>
    <div class="space-y-4">
      <div>
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.label :password, "Mật khẩu", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-blue-600" %>
          <%= f.label :remember_me, "Ghi nhớ đăng nhập", class: "text-sm text-gray-700" %>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Đăng nhập",
              class: "w-full bg-blue-600 text-white py-2 px-4 rounded-md text-sm font-semibold hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
