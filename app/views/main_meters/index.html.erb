<% content_for :title, t("main_meters.index.title") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-semibold text-gray-900"><%= t("main_meters.index.title") %></h1>
  <%= link_to t("main_meters.index.new_button"), new_main_meter_path,
        class: "inline-flex items-center gap-1.5 rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors" %>
</div>

<p class="mb-4 text-sm text-gray-600"><%= t("main_meters.index.subtitle") %></p>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left font-medium text-gray-600 w-10"><%= t("main_meters.index.columns.stt") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("main_meters.index.columns.name") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("main_meters.index.columns.organizations") %></th>
        <th class="px-4 py-3 text-right font-medium text-gray-600"><%= t("main_meters.index.columns.position") %></th>
        <th class="px-4 py-3 text-left font-medium text-gray-600"><%= t("main_meters.index.columns.actions") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @main_meters.any? %>
        <% @main_meters.each_with_index do |main_meter, idx| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-500"><%= idx + 1 %></td>
            <td class="px-4 py-3 font-medium text-gray-900"><%= main_meter.name %></td>
            <td class="px-4 py-3 text-gray-700">
              <% if main_meter.organizations.any? %>
                <%= main_meter.organizations.map(&:name).join(", ") %>
              <% else %>
                <span class="text-gray-400 italic"><%= t("main_meters.index.no_organizations") %></span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right text-gray-700"><%= main_meter.position %></td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <%= link_to t("main_meters.actions.edit"), edit_main_meter_path(main_meter),
                      class: "text-blue-600 hover:underline text-xs" %>
                <%= button_to t("main_meters.actions.delete"), main_meter_path(main_meter),
                      method: :delete,
                      data: { turbo_confirm: t("main_meters.actions.delete_confirm") },
                      class: "text-red-600 hover:underline text-xs bg-transparent border-0 cursor-pointer p-0" %>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="5" class="px-4 py-8 text-center text-gray-400"><%= t("main_meters.index.empty") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
