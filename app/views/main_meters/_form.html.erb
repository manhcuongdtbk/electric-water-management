<%= form_with model: main_meter do |f| %>
  <% if main_meter.errors.any? %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
      <ul class="list-disc pl-4 space-y-0.5">
        <% main_meter.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4 max-w-2xl">
    <div>
      <%= f.label :name, t("main_meters.form.name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
            required: true %>
      <p class="mt-1 text-xs text-gray-500"><%= t("main_meters.form.name_hint") %></p>
    </div>

    <div>
      <%= f.label :code, t("main_meters.form.code"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :code,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
            required: true %>
      <p class="mt-1 text-xs text-gray-500"><%= t("main_meters.form.code_hint") %></p>
    </div>

    <div>
      <%= f.label :position, t("main_meters.form.position"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :position,
            class: "block w-32 rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
            min: 0 %>
    </div>

    <div>
      <%= f.label :notes, t("main_meters.form.notes"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :notes, rows: 2,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <span class="block text-sm font-medium text-gray-700 mb-1"><%= t("main_meters.form.organizations") %></span>
      <p class="mb-2 text-xs text-gray-500"><%= t("main_meters.form.organizations_hint") %></p>
      <% if @available_organizations.any? %>
        <div class="rounded-md border border-gray-300 px-3 py-2 max-h-72 overflow-y-auto bg-gray-50">
          <% selected_ids = main_meter.organizations.pluck(:id) %>
          <% @available_organizations.each do |org| %>
            <% checked = selected_ids.include?(org.id) %>
            <% other = org.main_meter_id.present? && org.main_meter_id != main_meter.id %>
            <label class="flex items-start gap-2 py-1 text-sm <%= 'text-gray-500' if other %>">
              <%= check_box_tag "main_meter[organization_ids][]", org.id, checked,
                    id: "main_meter_organization_ids_#{org.id}",
                    class: "mt-0.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
              <span class="flex flex-col">
                <span class="font-medium"><%= org.name %> <span class="text-xs text-gray-400">(<%= org.code %>)</span></span>
                <% if other && org.main_meter %>
                  <span class="text-xs text-amber-600"><%= t("main_meters.form.org_in_other", main_meter: org.main_meter.name) %></span>
                <% end %>
              </span>
            </label>
          <% end %>
          <%= hidden_field_tag "main_meter[organization_ids][]", "" %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 italic"><%= t("main_meters.form.no_organizations_available") %></p>
      <% end %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit main_meter.new_record? ? t("main_meters.form.submit_create") : t("main_meters.form.submit_update"),
            class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors cursor-pointer" %>
      <%= link_to t("main_meters.form.cancel"), main_meters_path,
            class: "text-sm text-gray-600 hover:underline" %>
    </div>
  </div>
<% end %>
