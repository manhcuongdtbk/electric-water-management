<% page_title t("audit_logs.show.page_title") %>

<div class="mb-4">
  <%= link_to "← #{t('audit_logs.show.back')}", audit_logs_path,
        class: "text-sm text-blue-600 hover:text-blue-800" %>
</div>

<div class="bg-white rounded-lg shadow border border-gray-200 p-4 mb-4">
  <h2 class="text-lg font-semibold mb-3"><%= t("audit_logs.show.metadata") %></h2>
  <dl class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
    <div>
      <dt class="text-gray-600"><%= t("audit_logs.table.time") %></dt>
      <dd class="font-medium"><%= @version.created_at.in_time_zone("Asia/Ho_Chi_Minh").strftime("%d/%m/%Y %H:%M:%S") %></dd>
    </div>
    <div>
      <dt class="text-gray-600"><%= t("audit_logs.table.item") %></dt>
      <dd class="font-medium">
        <%= t("audit_logs.item_types.#{@version.item_type}", default: @version.item_type) %>
        <span class="text-gray-400">#<%= @version.item_id %></span>
      </dd>
    </div>
    <div>
      <dt class="text-gray-600"><%= t("audit_logs.table.event") %></dt>
      <dd class="font-medium"><%= t("audit_logs.events.#{@version.event}", default: @version.event) %></dd>
    </div>
    <div>
      <dt class="text-gray-600"><%= t("audit_logs.table.whodunnit") %></dt>
      <dd class="font-medium">
        <%= @whodunnit_by_id[@version.whodunnit.to_i] || (@version.whodunnit.presence || "—") %>
      </dd>
    </div>
  </dl>
</div>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <div class="px-4 py-3 border-b border-gray-200">
    <h2 class="text-lg font-semibold"><%= t("audit_logs.show.changes") %></h2>
  </div>

  <% if @changes.is_a?(Hash) && @changes.any? %>
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("audit_logs.show.field") %></th>
          <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("audit_logs.show.before") %></th>
          <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("audit_logs.show.after") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @changes.each do |field, (before_value, after_value)| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-2 font-mono text-gray-900"><%= field %></td>
            <td class="px-4 py-2 text-gray-700"><pre class="whitespace-pre-wrap"><%= before_value.inspect %></pre></td>
            <td class="px-4 py-2 text-gray-700"><pre class="whitespace-pre-wrap"><%= after_value.inspect %></pre></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% elsif @before_object.is_a?(Hash) && @before_object.any? %>
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("audit_logs.show.field") %></th>
          <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("audit_logs.show.before") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @before_object.each do |field, value| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-2 font-mono text-gray-900"><%= field %></td>
            <td class="px-4 py-2 text-gray-700"><pre class="whitespace-pre-wrap"><%= value.inspect %></pre></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-4 py-6 text-center text-gray-500"><%= t("audit_logs.show.no_changes") %></p>
  <% end %>
</div>
