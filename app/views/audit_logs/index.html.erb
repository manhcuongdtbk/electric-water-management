<% page_title t("audit_logs.page_title") %>

<%
  event_options = @events.map { |ev| [t("audit_logs.events.#{ev}"), ev] }
  item_type_options = @audited_models.map { |m| [t("audit_logs.item_types.#{m}", default: m), m] }
  user_options = @users.map { |username, id| [username, id] }
%>

<%= render "shared/list_toolbar",
      url: audit_logs_path,
      total_count: @total_count,
      show_search: false,
      per_page_storage_key: "audit_logs_per_page",
      filters: [
        { label: t("audit_logs.filters.item_type_label"), param: :item_type,
          options: item_type_options, selected: params[:item_type] },
        { label: t("audit_logs.filters.event_label"), param: :event,
          options: event_options, selected: params[:event] },
        { label: t("audit_logs.filters.whodunnit_label"), param: :whodunnit,
          options: user_options, selected: params[:whodunnit] },
        { label: t("audit_logs.filters.from_label"), param: :from,
          type: :date, value: params[:from] },
        { label: t("audit_logs.filters.to_label"), param: :to,
          type: :date, value: params[:to] }
      ] %>

<div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("audit_logs.table.time") %></th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("audit_logs.table.whodunnit") %></th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("audit_logs.table.event") %></th>
        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-600 uppercase"><%= t("audit_logs.table.item") %></th>
        <%= list_header t("common.list.actions"), align: :right %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @versions.empty? %>
        <tr><td colspan="5" class="px-4 py-6 text-center text-gray-500"><%= t("common.list.no_records") %></td></tr>
      <% end %>
      <% @versions.each do |v| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-2 text-gray-700 whitespace-nowrap">
            <%= v.created_at.in_time_zone("Asia/Ho_Chi_Minh").strftime("%d/%m/%Y %H:%M:%S") %>
          </td>
          <td class="px-4 py-2 text-gray-700">
            <%= @whodunnit_by_id[v.whodunnit.to_i] || (v.whodunnit.presence || "—") %>
          </td>
          <td class="px-4 py-2">
            <%
              event_color = case v.event
                            when "create" then "bg-green-100 text-green-700"
                            when "update" then "bg-blue-100 text-blue-700"
                            when "destroy" then "bg-red-100 text-red-700"
                            else "bg-gray-100 text-gray-700"
                            end
            %>
            <span class="px-2 py-0.5 rounded text-xs <%= event_color %>">
              <%= t("audit_logs.events.#{v.event}", default: v.event) %>
            </span>
          </td>
          <td class="px-4 py-2 text-gray-900">
            <%= t("audit_logs.item_types.#{v.item_type}", default: v.item_type) %>
            <span class="text-gray-400">#<%= v.item_id %></span>
          </td>
          <td class="px-4 py-2 text-sm text-right">
            <%= link_to "Xem", audit_log_path(v),
                  class: "text-blue-600 hover:text-blue-800" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
