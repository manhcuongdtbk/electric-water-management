<%= form_with model: assignment,
              url: assignment.new_record? ? pump_station_assignments_path(pump_station) : pump_station_assignment_path(pump_station, assignment),
              method: assignment.new_record? ? :post : :patch do |f| %>
  <% if assignment.errors.any? %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
      <ul class="list-disc pl-4 space-y-0.5">
        <% assignment.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <% if assignment.new_record? %>
      <%
        selected_type  = assignment.assignable_type.presence || "Organization"
        orgs           = available_assignables[:organizations]
        contact_points = available_assignables[:contact_points]
        work_groups    = available_assignables[:work_groups]
      %>
      <div data-controller="assignable-type-picker">
        <span class="block text-sm font-medium text-gray-700 mb-1">
          <%= t("pump_station_assignments.form.assignable_type") %>
        </span>
        <div class="flex flex-wrap gap-3 mb-3">
          <% [
            [ "Organization",  t("pump_station_assignments.form.assignable_type_organization") ],
            [ "ContactPoint",  t("pump_station_assignments.form.assignable_type_contact_point") ],
            [ "WorkGroup",     t("pump_station_assignments.form.assignable_type_work_group") ]
          ].each do |value, label| %>
            <label class="inline-flex items-center gap-2 text-sm">
              <%= f.radio_button :assignable_type, value,
                    checked: selected_type == value,
                    data: { assignable_type_picker_target: "radio",
                            action: "change->assignable-type-picker#typeChanged" },
                    class: "text-blue-600 focus:ring-blue-500" %>
              <span><%= label %></span>
            </label>
          <% end %>
        </div>

        <div data-assignable-type-picker-target="field"
             data-assignable-type="Organization"
             class="<%= 'hidden' if selected_type != 'Organization' %>">
          <%= f.label :assignable_id, t("pump_station_assignments.form.organization"),
                class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :assignable_id,
                options_from_collection_for_select(orgs, :id, :name,
                                                   selected_type == "Organization" ? assignment.assignable_id : nil),
                { include_blank: t("pump_station_assignments.form.organization_prompt") },
                class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
                disabled: selected_type != "Organization",
                required: selected_type == "Organization" %>
        </div>

        <div data-assignable-type-picker-target="field"
             data-assignable-type="ContactPoint"
             class="<%= 'hidden' if selected_type != 'ContactPoint' %>">
          <%= label_tag "pump_station_assignment_assignable_id_cp",
                t("pump_station_assignments.form.contact_point"),
                class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= select_tag "pump_station_assignment[assignable_id]",
                options_from_collection_for_select(
                  contact_points,
                  :id,
                  ->(cp) { "#{cp.name} — #{cp.organization.name}" },
                  selected_type == "ContactPoint" ? assignment.assignable_id : nil
                ),
                id: "pump_station_assignment_assignable_id_cp",
                include_blank: t("pump_station_assignments.form.contact_point_prompt"),
                class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
                disabled: selected_type != "ContactPoint",
                required: selected_type == "ContactPoint" %>
        </div>

        <div data-assignable-type-picker-target="field"
             data-assignable-type="WorkGroup"
             class="<%= 'hidden' if selected_type != 'WorkGroup' %>">
          <%= label_tag "pump_station_assignment_assignable_id_wg",
                t("pump_station_assignments.form.work_group"),
                class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= select_tag "pump_station_assignment[assignable_id]",
                options_from_collection_for_select(
                  work_groups, :id, :name,
                  selected_type == "WorkGroup" ? assignment.assignable_id : nil
                ),
                id: "pump_station_assignment_assignable_id_wg",
                include_blank: t("pump_station_assignments.form.work_group_prompt"),
                class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500",
                disabled: selected_type != "WorkGroup",
                required: selected_type == "WorkGroup" %>
        </div>
      </div>
    <% end %>

    <div>
      <%= f.label :fixed_pump_percentage,
            t("pump_station_assignments.form.fixed_pump_percentage"),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :fixed_pump_percentage,
            step: "0.01", min: 0, max: 100,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      <p class="text-xs text-gray-500 mt-1">
        <%= t("pump_station_assignments.form.fixed_pump_percentage_hint") %>
      </p>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit assignment.new_record? ? t("pump_station_assignments.form.submit_create") : t("pump_station_assignments.form.submit_update"),
            class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors cursor-pointer" %>
      <%= link_to t("pump_station_assignments.form.cancel"), pump_stations_path,
            class: "text-sm text-gray-600 hover:underline" %>
    </div>
  </div>
<% end %>
