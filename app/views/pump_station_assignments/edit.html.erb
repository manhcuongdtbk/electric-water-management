<% content_for :title, t("pump_station_assignments.edit.title") %>

<div class="mb-6 flex items-center gap-2 text-sm text-gray-500">
  <%= link_to t("pump_stations.index.title"), pump_stations_path, class: "hover:underline" %>
  <span>/</span>
  <span class="text-gray-900"><%= t("pump_station_assignments.edit.title") %></span>
</div>

<div class="bg-white rounded-lg border border-gray-200 p-6 max-w-md">
  <h1 class="text-xl font-semibold text-gray-900 mb-1"><%= t("pump_station_assignments.edit.title") %></h1>
  <p class="text-sm text-gray-500 mb-6">
    <%= @pump_station.name %> · <%= @assignment.organization.name %>
  </p>

  <%= render "form",
        pump_station: @pump_station,
        assignment: @assignment,
        available_organizations: [] %>
</div>
