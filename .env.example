# Sao chép file này thành .env rồi điền giá trị thực trước khi chạy docker compose up.
#
#   cp .env.example .env
#   # Sửa giá trị trong .env
#   docker compose up -d

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=electric_water_management
POSTGRES_PASSWORD=              # Bắt buộc — đặt mật khẩu mạnh
POSTGRES_DB=electric_water_management_production

# ── Rails ───────────────────────────────────────────────────
# Tạo bằng: docker compose run --rm app bin/rails secret
SECRET_KEY_BASE=                # Bắt buộc — chuỗi 128 ký tự hex
# Nội dung file config/master.key (dùng giải mã credentials.yml.enc)
RAILS_MASTER_KEY=               # Bắt buộc — chuỗi 32 ký tự hex
