#!/usr/bin/env bash
# Thiết lập sao lưu tự động Docker volumes sang ổ cứng phụ.
#
# Cách dùng:
#   sudo ./script/setup-auto-backup /mnt/backup
#
# Sau khi chạy:
# - Sao lưu tự động mỗi ngày lúc 2:00 sáng
# - Dữ liệu lưu tại: /mnt/backup/ewm-backup/
# - Log tại: /mnt/backup/ewm-backup/backup.log
# - Giữ tối đa 7 bản sao lưu (xóa bản cũ nhất tự động)

set -e

BACKUP_DEST="${1}"
EWM_DIR="$(cd "$(dirname "$0")/.." && pwd)"

if [ -z "$BACKUP_DEST" ]; then
  echo "Thiếu đường dẫn ổ cứng phụ."
  echo "Cách dùng: sudo $0 /mnt/backup"
  exit 1
fi

if [ ! -d "$BACKUP_DEST" ]; then
  echo "Thư mục $BACKUP_DEST không tồn tại."
  echo "Mount ổ cứng phụ trước, ví dụ: sudo mount /dev/sdb1 /mnt/backup"
  exit 1
fi

BACKUP_DIR="$BACKUP_DEST/ewm-backup"
BACKUP_SCRIPT="$EWM_DIR/script/run-backup"

mkdir -p "$BACKUP_DIR"

# Tạo script sao lưu
cat > "$BACKUP_SCRIPT" << EOF
#!/usr/bin/env bash
# Script sao lưu tự động — chạy bởi cron, không chạy thủ công.
set -e

BACKUP_DIR="$BACKUP_DIR"
EWM_DIR="$EWM_DIR"
TIMESTAMP=\$(date +%Y%m%d_%H%M%S)
CURRENT="\$BACKUP_DIR/\$TIMESTAMP"

mkdir -p "\$CURRENT"

# Sao lưu database (pg_dump)
cd "\$EWM_DIR"
docker compose exec -T postgres pg_dump -U \${POSTGRES_USER:-electric_water_management} -Fc \${POSTGRES_DB:-electric_water_management_production} > "\$CURRENT/database.dump"

# Sao lưu backups volume (file sao lưu trong app)
docker compose cp app:/rails/storage/backups "\$CURRENT/app-backups" 2>/dev/null || true

# Giữ tối đa 7 bản, xóa cũ nhất
cd "\$BACKUP_DIR"
ls -dt */ 2>/dev/null | tail -n +8 | xargs rm -rf 2>/dev/null || true

echo "\$(date): Sao lưu hoàn tất → \$CURRENT" >> "\$BACKUP_DIR/backup.log"
EOF

chmod +x "$BACKUP_SCRIPT"

# Thêm vào cron (mỗi ngày 2:00 sáng)
CRON_LINE="0 2 * * * $BACKUP_SCRIPT"
(crontab -l 2>/dev/null | grep -v "$BACKUP_SCRIPT"; echo "$CRON_LINE") | crontab -

echo ""
echo "=== Thiết lập sao lưu tự động hoàn tất ==="
echo "Thư mục sao lưu: $BACKUP_DIR"
echo "Lịch:            Mỗi ngày lúc 2:00 sáng"
echo "Giữ tối đa:      7 bản (xóa cũ nhất tự động)"
echo "Log:             $BACKUP_DIR/backup.log"
echo "Script:          $BACKUP_SCRIPT"
echo ""
echo "Kiểm tra cron đã thêm:"
crontab -l | grep ewm
